{%- comment -%}
  Outputs apple-touch-icon, web app manifest link, and related meta tags so
  the bundled app-icon.png (black bg, white logo) is used as the icon when
  users add the site to their mobile home screen.
{%- endcomment -%}

{%- assign app_icon = 'app-icon.png' | asset_url -%}

<link rel="apple-touch-icon" sizes="180x180" href="{{ app_icon }}">
<link rel="apple-touch-icon" sizes="192x192" href="{{ app_icon }}">
<link rel="apple-touch-icon" sizes="512x512" href="{{ app_icon }}">
<link rel="apple-touch-icon-precomposed" href="{{ app_icon }}">

<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="{{ shop.name | escape }}">
<meta name="mobile-web-app-capable" content="yes">
<meta name="application-name" content="{{ shop.name | escape }}">

<link rel="manifest" href="{{ 'manifest.json' | asset_url }}">

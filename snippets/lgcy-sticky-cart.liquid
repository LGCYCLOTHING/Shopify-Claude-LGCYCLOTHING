{% comment %}
  LGCY — Sticky add-to-cart popup (product page only).

  Shows in bottom-right (desktop) / full-width bar at bottom (mobile)
  when the main ATC button scrolls out of viewport. Fades in/out.

  The popup's "Add to Cart" button triggers the main ATC button via
  a programmatic click — so all variant logic + cart drawer rendering
  is handled by the user's existing add-to-cart code (no duplication).

  Price stays in sync via MutationObserver mirroring the on-page price.
{% endcomment %}

{%- if template.name == 'product' and product -%}

<div id="lgcy-sticky-cart" class="lgcy-sticky-cart" role="region" aria-label="Quick add to cart" aria-hidden="true">
  <a href="{{ product.url }}" class="lgcy-sticky-cart__media" tabindex="-1" aria-hidden="true">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 160 }}"
        alt=""
        width="56"
        height="56"
        loading="lazy"
      >
    {%- endif -%}
  </a>

  <div class="lgcy-sticky-cart__info">
    <a href="{{ product.url }}" class="lgcy-sticky-cart__title">{{ product.title | escape }}</a>
    <span class="lgcy-sticky-cart__price" data-lgcy-sticky-price>
      {{ product.selected_or_first_available_variant.price | money }}
    </span>
  </div>

  <button type="button" class="lgcy-sticky-cart__btn" data-lgcy-sticky-add aria-label="Add {{ product.title | escape }} to cart">
    Add to Cart
  </button>
</div>

<style>
  .lgcy-sticky-cart {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1500;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 8px 8px 12px;
    background: linear-gradient(
      -75deg,
      rgba(255, 255, 255, 0.82),
      rgba(255, 255, 255, 0.94),
      rgba(255, 255, 255, 0.82)
    );
    -webkit-backdrop-filter: blur(18px) saturate(160%);
            backdrop-filter: blur(18px) saturate(160%);
    border-radius: 14px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(0, 0, 0, 0.08),
      0 14px 36px -10px rgba(0, 0, 0, 0.28),
      0 0 0 1px rgba(0, 0, 0, 0.06);
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    transition:
      opacity 360ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 360ms cubic-bezier(0.4, 0, 0.2, 1);
    max-width: calc(100vw - 32px);
  }

  .lgcy-sticky-cart.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .lgcy-sticky-cart__media {
    flex-shrink: 0;
    display: block;
    width: 52px;
    height: 52px;
    border-radius: 8px;
    overflow: hidden;
    background: #f3f3f3;
    text-decoration: none;
  }
  .lgcy-sticky-cart__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lgcy-sticky-cart__info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
    flex: 1;
  }

  .lgcy-sticky-cart__title {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #000;
    text-decoration: none;
    border-bottom: 0;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 220px;
    transition: opacity 0.2s ease;
  }
  .lgcy-sticky-cart__title:hover {
    opacity: 0.7;
  }

  .lgcy-sticky-cart__price {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #555;
    line-height: 1;
  }

  /* Liquid-glass ATC pill inside the popup */
  .lgcy-sticky-cart__btn {
    --border-width: 1px;
    position: relative;
    flex-shrink: 0;
    isolation: isolate;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #000;
    background: linear-gradient(
      -75deg,
      rgba(255, 255, 255, 0.55),
      rgba(255, 255, 255, 0.85),
      rgba(255, 255, 255, 0.55)
    );
    -webkit-backdrop-filter: blur(8px) saturate(150%);
            backdrop-filter: blur(8px) saturate(150%);
    border: none;
    border-radius: 10px;
    padding: 12px 22px;
    cursor: pointer;
    white-space: nowrap;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 0.25em 0.5em -0.125em rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.2s cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 0.2s ease,
      background 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .lgcy-sticky-cart__btn::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 10px;
    width: calc(100% + var(--border-width));
    height: calc(100% + var(--border-width));
    top: calc(0% - var(--border-width) / 2);
    left: calc(0% - var(--border-width) / 2);
    padding: var(--border-width);
    box-sizing: border-box;
    background: conic-gradient(
      from -75deg at 50% 50%,
      rgba(0, 0, 0, 0.4),
      rgba(0, 0, 0, 0) 5% 40%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0) 60% 95%,
      rgba(0, 0, 0, 0.4)
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  .lgcy-sticky-cart__btn:hover {
    transform: scale(0.985);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.15),
      0 0.4em 0.7em -0.15em rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(0, 0, 0, 0.12);
  }
  .lgcy-sticky-cart__btn:active {
    transform: scale(0.965);
  }
  .lgcy-sticky-cart__btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* === Mobile === */
  @media (max-width: 749px) {
    .lgcy-sticky-cart {
      bottom: 12px;
      right: 12px;
      left: 12px;
      max-width: none;
      padding: 6px 6px 6px 10px;
      gap: 10px;
      border-radius: 12px;
    }
    .lgcy-sticky-cart__media {
      width: 44px;
      height: 44px;
      border-radius: 6px;
    }
    .lgcy-sticky-cart__btn {
      border-radius: 8px;
    }
    .lgcy-sticky-cart__btn::after {
      border-radius: 8px;
    }
    .lgcy-sticky-cart__title {
      font-size: 12px;
      max-width: none;
    }
    .lgcy-sticky-cart__price {
      font-size: 11px;
    }
    .lgcy-sticky-cart__btn {
      padding: 10px 16px;
      font-size: 11px;
    }
  }

  /* Respect reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .lgcy-sticky-cart {
      transition: opacity 200ms linear;
      transform: none !important;
    }
  }
</style>

<script>
  (function () {
    var popup = document.getElementById('lgcy-sticky-cart');
    if (!popup) return;

    /* Main ATC selectors — tries every variant present in the theme */
    var MAIN_ATC_SELECTORS = [
      '.rp-btn-cart',
      '.product-form__submit',
      'product-form button[name="add"]',
      'form[action*="/cart/add"] button[type="submit"]',
      'button[name="add"]'
    ];

    /* Trigger element — popup waits for the user to scroll fully past this
       block before it appears. We watch the whole product-detail section
       (gallery + info column together) so the popup only shows once the
       editorial / related-products area starts. */
    var GALLERY_SELECTORS = [
      '.rp-wrap',
      '.rp-gallery',
      '.product__media-wrapper',
      '.product__media-list',
      'media-gallery',
      '.product-media-container'
    ];

    /* Main price selectors */
    var MAIN_PRICE_SELECTORS = [
      '.rp-price',
      '.price__regular .price-item--regular',
      '.product__price .price-item--regular',
      '.product__price',
      '[data-product-price]'
    ];

    function findFirst(selectors) {
      for (var i = 0; i < selectors.length; i++) {
        var el = document.querySelector(selectors[i]);
        if (el) return el;
      }
      return null;
    }

    /* Two independent conditions drive visibility:
       - past the product image (set by gallery observer)
       - footer not yet visible (set by footer observer)
       Popup shows only when BOTH are true. */
    var scrolledPastImage = false;
    var footerVisible = false;

    function syncVisibility() {
      if (scrolledPastImage && !footerVisible) {
        popup.classList.add('is-visible');
        popup.setAttribute('aria-hidden', 'false');
      } else {
        popup.classList.remove('is-visible');
        popup.setAttribute('aria-hidden', 'true');
      }
    }
    function showPopup() { scrolledPastImage = true;  syncVisibility(); }
    function hidePopup() { scrolledPastImage = false; syncVisibility(); }

    function attachPriceMirror() {
      var stickyPriceEl = popup.querySelector('[data-lgcy-sticky-price]');
      if (!stickyPriceEl) return;
      var mainPriceEl = findFirst(MAIN_PRICE_SELECTORS);
      if (!mainPriceEl) return;
      var sync = function () {
        var txt = (mainPriceEl.textContent || '').trim();
        if (txt) stickyPriceEl.textContent = txt;
      };
      sync();
      var mo = new MutationObserver(sync);
      mo.observe(mainPriceEl, { childList: true, characterData: true, subtree: true });
    }

    function attachClick(mainBtn) {
      var stickyBtn = popup.querySelector('[data-lgcy-sticky-add]');
      if (!stickyBtn) return;
      stickyBtn.addEventListener('click', function (e) {
        e.preventDefault();
        var btn = findFirst(MAIN_ATC_SELECTORS) || mainBtn;
        if (btn && !btn.disabled) {
          btn.click();
        }
      });
    }

    function attachObserver(mainBtn) {
      if (!('IntersectionObserver' in window)) {
        /* Fallback: show after scrolling ~1 viewport */
        var onScroll = function () {
          if (window.scrollY > window.innerHeight * 0.9) showPopup(); else hidePopup();
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        return;
      }

      /* Prefer the product image / gallery as the trigger element — popup
         shows once the user has scrolled past the main product image area.
         Falls back to the ATC button with a generous top rootMargin so the
         popup still doesn't appear too early. */
      var trigger = findFirst(GALLERY_SELECTORS) || mainBtn;
      var isGallery = trigger !== mainBtn;

      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            hidePopup();
          } else {
            showPopup();
          }
        });
      }, {
        threshold: 0,
        /* When watching gallery: trigger fires when its bottom leaves viewport.
           When watching ATC: pad the top by ~80% of viewport so the popup
           only shows after a real scroll past the image area. */
        rootMargin: isGallery ? '0px 0px 0px 0px' : '80% 0px 0px 0px'
      });
      io.observe(trigger);
    }

    function attachFooterObserver() {
      var footer = document.querySelector('.lgcy-footer, footer.lgcy-footer, footer[role="contentinfo"], footer.section-footer, footer');
      if (!footer || !('IntersectionObserver' in window)) return;
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          footerVisible = entry.isIntersecting;
          syncVisibility();
        });
      }, {
        threshold: 0,
        rootMargin: '0px 0px 0px 0px'
      });
      io.observe(footer);
    }

    function init() {
      var mainBtn = findFirst(MAIN_ATC_SELECTORS);
      if (!mainBtn) {
        /* The ATC may be injected later (custom liquid PDP). Retry briefly. */
        if (init._tries === undefined) init._tries = 0;
        if (init._tries++ < 30) {
          setTimeout(init, 250);
        }
        return;
      }
      attachObserver(mainBtn);
      attachClick(mainBtn);
      attachPriceMirror();
      attachFooterObserver();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{%- endif -%}

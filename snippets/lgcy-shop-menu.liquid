
{% comment %}
  LGCYCLOTHING — Shop Side Panel
  Save as: snippets/lgcy-shop-menu.liquid

  SCHEMA BLOCKS to add to header.liquid {% schema %}:
  Add to "blocks" array (alongside the @app block):

  {
    "type": "shop_link",
    "name": "Shop Panel Link",
    "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Collection Name" },
      { "type": "url", "id": "url", "label": "Link URL" },
      {
        "type": "select",
        "id": "section",
        "label": "Section",
        "options": [
          { "value": "shop", "label": "Shop" },
          { "value": "explore", "label": "Explore" },
          { "value": "support", "label": "Support" }
        ],
        "default": "shop"
      },
      { "type": "checkbox", "id": "show_arrow", "label": "Show arrow", "default": true }
    ]
  },
  {
    "type": "shop_image",
    "name": "Shop Panel Image",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "label", "label": "Image label", "default": "Collection" },
      { "type": "url", "id": "url", "label": "Discover link URL" }
    ]
  }

  Also add to "settings" array:
  {
    "type": "header",
    "content": "Shop Panel"
  },
  {
    "type": "checkbox",
    "id": "shop_panel_show_shop_label",
    "label": "Show 'Shop' section label",
    "default": true
  },
  {
    "type": "checkbox",
    "id": "shop_panel_show_explore_label",
    "label": "Show 'Explore' section label",
    "default": true
  },
  {
    "type": "checkbox",
    "id": "shop_panel_show_support_label",
    "label": "Show 'Support' section label",
    "default": true
  }
{% endcomment %}

<style>
  @font-face {
    font-family: 'CormorantGaramond';
    src: url('{{ 'CormorantGaramond-Italic.woff2' | asset_url }}') format('woff2');
    font-weight: 600;
    font-style: italic;
    font-display: swap;
  }

  /* ── Tighter header ── */
  .header {
    padding-top: 14px !important;
    padding-bottom: 14px !important;
  }




  /* ── Shop trigger ── */
  .lgcy-shop-trigger-wrap {
    display: inline-flex;
    align-items: center;
    margin-right: 0;
    margin-left: 1rem;
    mix-blend-mode: normal !important;
    isolation: isolate;
  }

  .lgcy-shop-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: system-ui, -apple-system, 'Helvetica Neue', Arial, sans-serif !important;
    font-weight: 900 !important;
    font-size: 14px !important;
    font-style: normal !important;
    letter-spacing: -0.04em !important;
    text-transform: uppercase !important;
    color: currentColor;
    padding: 1.2rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    -webkit-tap-highlight-color: transparent;
    position: relative;
    text-decoration: none;
    mix-blend-mode: normal !important;
  }

  /* Center-out underline on Shop trigger */
  .lgcy-shop-btn::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: currentColor;
    transition: width 0.5s ease;
  }

  .lgcy-shop-btn:hover::after,
  .lgcy-shop-btn.lgcy-active::after {
    width: 85%;
  }

  /* ── Overlay ── */
  .lgcy-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    pointer-events: none;
    background-color: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    transition: background-color 0.55s ease, backdrop-filter 0.55s ease, -webkit-backdrop-filter 0.55s ease;
  }

  .lgcy-menu-overlay.lgcy-open {
    pointer-events: auto;
    background-color: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  /* ── Side panel ── */
  .lgcy-side-panel {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 10002;
    width: 620px;
    background: transparent;
    transform: translateX(-100%);
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .lgcy-panel-images {
    display: none !important;
  }

  .lgcy-side-panel.lgcy-open {
    transform: translateX(0);
  }

  /* ── Left nav column ── */
  .lgcy-panel-nav {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    padding: 100px 0 40px;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* ── Section labels ── */
  .lgcy-panel-section-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    padding: 0 28px 8px;
    margin-top: 24px;
  }

  .lgcy-panel-section-label:first-child {
    margin-top: 0;
  }

  /* ── Nav links with center-out underline ── */
  .lgcy-panel-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    text-decoration: none;
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: clamp(18px, 3vw, 22px);
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 1.2;
    position: relative;
  }

  /* Center-out underline on nav links */
  .lgcy-panel-link__text {
    position: relative;
    display: inline-block;
  }

  .lgcy-panel-link__text::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 1.5px;
    background: #ffffff;
    transition: width 0.4s ease;
  }

  .lgcy-panel-link:hover .lgcy-panel-link__text::after {
    width: 100%;
  }

  /* Secondary links */
  .lgcy-panel-link--secondary {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.5);
    font-size: clamp(13px, 2vw, 15px);
    padding: 8px 28px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .lgcy-panel-link--secondary .lgcy-panel-link__text::after {
    background: rgba(255, 255, 255, 0.5);
    height: 1px;
  }

  .lgcy-panel-link--secondary:hover .lgcy-panel-link__text::after {
    width: 100%;
  }

  /* Arrow */
  .lgcy-panel-link__arrow {
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    flex-shrink: 0;
    margin-left: 10px;
  }

  .lgcy-panel-link:hover .lgcy-panel-link__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .lgcy-panel-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
    margin: 14px 0;
  }

  .lgcy-panel-bottom {
    margin-top: auto;
    padding-top: 8px;
  }

  .lgcy-panel-bottom-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    padding: 0 28px 6px;
  }

  .lgcy-panel-bottom .lgcy-panel-divider {
    background: rgba(255, 255, 255, 0.5);
    margin: 0 28px 8px;
    height: 1px;
    display: block;
  }

  .lgcy-panel-link--bottom {
    font-size: clamp(13px, 2vw, 15px) !important;
    font-weight: 900 !important;
    color: rgba(255, 255, 255, 0.6) !important;
    padding: 7px 28px !important;
  }

  /* Close button */
  .lgcy-panel-close {
    position: absolute;
    top: 18px;
    left: 222px;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: #ffffff;
    padding: 0;
    opacity: 0.5;
    transition: opacity 0.15s ease;
    z-index: 10;
    -webkit-tap-highlight-color: transparent;
  }

  .lgcy-panel-close:hover { opacity: 1; }

  .lgcy-panel-close { display: none !important; }

  /* ── Right image column ── */
  .lgcy-panel-images {
    display: grid;
    overflow: hidden;
    position: relative;
  }

  .lgcy-panel-images--1 { grid-template-rows: 1fr; }
  .lgcy-panel-images--2 { grid-template-rows: 1fr 1fr; }
  .lgcy-panel-images--3 { grid-template-rows: 1fr 1fr 1fr; }

  /* ── Image wrap with hover blur + discover ── */
  .lgcy-panel-image-wrap {
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .lgcy-panel-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: filter 0.3s ease, transform 0.4s ease;
  }

  /* Dark base overlay */
  .lgcy-panel-image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.15);
    transition: background 0.3s ease;
    z-index: 1;
  }

  /* Discover button — hidden by default */
  .lgcy-panel-image-discover {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    text-decoration: none;
  }

  .lgcy-panel-image-discover span {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.7);
    padding: 10px 20px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    background: rgba(0,0,0,0.25);
    transition: background 0.2s ease;
  }

  .lgcy-panel-image-discover span:hover {
    background: rgba(0,0,0,0.5);
  }

  /* Image caption */
  .lgcy-panel-image-label {
    position: absolute;
    bottom: 12px;
    left: 14px;
    z-index: 3;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  /* On hover: blur image, darken overlay, show discover */
  .lgcy-panel-image-wrap:hover img {
    filter: blur(3px);
    transform: scale(1.02);
  }

  .lgcy-panel-image-wrap:hover .lgcy-panel-image-overlay {
    background: rgba(0, 0, 0, 0.45);
  }

  .lgcy-panel-image-wrap:hover .lgcy-panel-image-discover {
    opacity: 1;
  }

  .lgcy-panel-image-wrap:hover .lgcy-panel-image-label {
    opacity: 0;
  }

  /* Placeholder */
  .lgcy-panel-image-placeholder {
    width: 100%;
    height: 100%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 10px;
    color: #bbb;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    padding: 20px;
  }

  @media (max-width: 989px) {
    /* Hide the desktop Shop trigger button — hamburger replaces it */
    .lgcy-shop-trigger-wrap {
      display: none !important;
    }

    /* Full-width single-column panel on mobile */
    .lgcy-side-panel {
      width: 100vw !important;
      max-width: 100vw !important;
      grid-template-columns: 1fr !important;
    }

    /* Hide right image column on mobile */
    .lgcy-panel-images {
      display: none !important;
    }

    /* Nav column fills full panel */
    .lgcy-panel-nav {
      border-right: none;
      padding: 100px 0 40px;
      width: 100%;
    }

    /* Move close button to top-right on mobile */
    .lgcy-panel-close {
      left: auto !important;
      right: 18px;
      top: 18px;
    }
  }

  /* ── When panel is open: lift header above the panels ── */
  body.lgcy-panel-open .section-header,
  body.lgcy-panel-open .section-header.shopify-section-group-header-group,
  body.lgcy-panel-open .shopify-section-header-sticky,
  body.lgcy-panel-open sticky-header {
    z-index: 10010 !important;
  }

  body.lgcy-panel-open .header-wrapper {
    z-index: 10010 !important;
    background: transparent !important;
  }

  /* Panel is dark glass — header stays white when open */

  /* Smooth color transition on nav items */
  .lgcy-shop-btn,
  .header__inline-menu .list-menu__item--link,
  .header__heading-link,
  .header__icon {
    transition: color 0.25s ease, mix-blend-mode 0s;
  }

  /* Buttons always visible above panel — no blending */
  .lgcy-shop-trigger-wrap .lgcy-shop-btn {
    mix-blend-mode: normal !important;
    color: #ffffff !important;
  }

  /* Content switching — only active pane visible */
  .lgcy-panel-content {
    display: none;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
  }
  .lgcy-panel-content.lgcy-active {
    display: flex;
  }
</style>

{%- comment %} ── Triggers ── {% endcomment %}
<div class="lgcy-shop-trigger-wrap" id="lgcy-shop-trigger-wrap">
  <button
    class="lgcy-shop-btn"
    id="lgcy-shop-btn"
    type="button"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="lgcy-side-panel"
  >
    Shop
  </button>
  <button
    class="lgcy-shop-btn lgcy-legacy-btn"
    id="lgcy-legacy-btn"
    type="button"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="lgcy-legacy-panel"
  >
    Legacy
    <img src="https://cdn.shopify.com/s/files/1/0688/4537/1578/files/Untitled_Project_-_Standard_6.svg" alt="" aria-hidden="true" width="20" height="14" style="height:14px;width:auto;margin-left:5px;vertical-align:middle;filter:brightness(0) invert(1);opacity:0.9;">
  </button>
</div>

<div class="lgcy-menu-overlay" id="lgcy-menu-overlay" aria-hidden="true"></div>

{%- comment %} ── Panel ── {% endcomment %}
<div
  class="lgcy-side-panel"
  id="lgcy-side-panel"
  role="dialog"
  aria-label="Shop menu"
  aria-hidden="true"
>
  <button class="lgcy-panel-close" id="lgcy-panel-close" aria-label="Close menu" type="button">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  {%- comment %} ── Shop content ── {% endcomment %}
  <div class="lgcy-panel-content lgcy-panel-content--shop lgcy-active">
  <nav class="lgcy-panel-nav" aria-label="Shop navigation">

    {%- comment %} Separate blocks by section ── {% endcomment %}
    {%- assign shop_links    = section.blocks | where: 'type', 'shop_link' -%}
    {%- assign shop_section  = shop_links | where: 'settings.section', 'shop' -%}
    {%- assign explore_section = shop_links | where: 'settings.section', 'explore' -%}
    {%- assign support_section = shop_links | where: 'settings.section', 'support' -%}

    {%- if shop_section.size > 0 -%}
      {%- for block in shop_section -%}
        <a href="{{ block.settings.url }}" class="lgcy-panel-link" {{ block.shopify_attributes }}>
          <span class="lgcy-panel-link__text">{{ block.settings.label }}</span>
          {%- if block.settings.show_arrow -%}
            <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- comment %} Fallback defaults if no blocks set ── {% endcomment %}
      <a href="{{ routes.collections_url }}/the-legacy-collection" class="lgcy-panel-link">
        <span class="lgcy-panel-link__text">LGCYCLOTHING</span>
        <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="{{ routes.collections_url }}/lgcy-glasses" class="lgcy-panel-link">
        <span class="lgcy-panel-link__text">LGCY.</span>
        <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="{{ routes.all_products_collection_url }}" class="lgcy-panel-link">
        <span class="lgcy-panel-link__text">All Products</span>
        <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}

    {%- if explore_section.size > 0 -%}
      <div class="lgcy-panel-divider"></div>
      {%- for block in explore_section -%}
        <a href="{{ block.settings.url }}" class="lgcy-panel-link" {{ block.shopify_attributes }}>
          <span class="lgcy-panel-link__text">{{ block.settings.label }}</span>
          {%- if block.settings.show_arrow -%}
            <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </a>
      {%- endfor -%}
    {%- else -%}
      <div class="lgcy-panel-divider"></div>
      <span class="lgcy-panel-section-label">Explore</span>
      <a href="/pages/about" class="lgcy-panel-link">
        <span class="lgcy-panel-link__text">About</span>
        <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/pages/contact" class="lgcy-panel-link">
        <span class="lgcy-panel-link__text">Contact</span>
        <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/apps/aftership" class="lgcy-panel-link">
        <span class="lgcy-panel-link__text">Track Order</span>
        <svg class="lgcy-panel-link__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}

    {%- if support_section.size > 0 -%}
      <div class="lgcy-panel-divider"></div>
      {%- if section.settings.shop_panel_show_support_label -%}
        <span class="lgcy-panel-section-label">Support</span>
      {%- endif -%}
      {%- for block in support_section -%}
        <a href="{{ block.settings.url }}" class="lgcy-panel-link lgcy-panel-link--secondary" {{ block.shopify_attributes }}>
          <span class="lgcy-panel-link__text">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    {%- else -%}
      <div class="lgcy-panel-divider"></div>
      <span class="lgcy-panel-section-label">Support</span>
      <a href="/policies/shipping-policy" class="lgcy-panel-link lgcy-panel-link--secondary">
        <span class="lgcy-panel-link__text">Shipping Policy</span>
      </a>
      <a href="/policies/refund-policy" class="lgcy-panel-link lgcy-panel-link--secondary">
        <span class="lgcy-panel-link__text">Returns & Refunds</span>
      </a>
      <a href="/policies/terms-of-service" class="lgcy-panel-link lgcy-panel-link--secondary">
        <span class="lgcy-panel-link__text">Terms of Service</span>
      </a>
      <a href="/policies/privacy-policy" class="lgcy-panel-link lgcy-panel-link--secondary">
        <span class="lgcy-panel-link__text">Privacy Policy</span>
      </a>
    {%- endif -%}

    {%- comment %} ── Bottom pinned links ── {% endcomment %}
    <div class="lgcy-panel-bottom">
      <span class="lgcy-panel-bottom-label">Account</span>
      <div class="lgcy-panel-divider"></div>
      <a href="{{ routes.account_url }}" class="lgcy-panel-link lgcy-panel-link--bottom">
        <span class="lgcy-panel-link__text">Orders</span>
      </a>
      <a href="{{ routes.account_url }}" class="lgcy-panel-link lgcy-panel-link--bottom">
        <span class="lgcy-panel-link__text">Profile</span>
      </a>
    </div>

  </nav>

  {%- comment %} ── RIGHT: Images — built from blocks ── {% endcomment %}
  {%- assign image_blocks = section.blocks | where: 'type', 'shop_image' -%}
  {%- assign image_count = image_blocks.size -%}
  {%- if image_count == 0 -%}{%- assign image_count = 2 -%}{%- endif -%}

  <div class="lgcy-panel-images lgcy-panel-images--{{ image_count }}">

    {%- if image_blocks.size > 0 -%}
      {%- for block in image_blocks -%}
        <div class="lgcy-panel-image-wrap" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | default: block.settings.label }}"
              loading="lazy"
              width="800"
              height="1200"
            >
            <div class="lgcy-panel-image-overlay"></div>
            {%- if block.settings.url != blank -%}
              <a href="{{ block.settings.url }}" class="lgcy-panel-image-discover">
                <span>Discover</span>
              </a>
            {%- endif -%}
            <span class="lgcy-panel-image-label">{{ block.settings.label }}</span>
          {%- else -%}
            <div class="lgcy-panel-image-placeholder">Add image in<br>Theme Editor</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- comment %} Fallback placeholders ── {% endcomment %}
      <div class="lgcy-panel-image-wrap">
        <div class="lgcy-panel-image-placeholder">Add image block<br>in Theme Editor</div>
      </div>
      <div class="lgcy-panel-image-wrap">
        <div class="lgcy-panel-image-placeholder">Add image block<br>in Theme Editor</div>
      </div>
    {%- endif -%}

  </div>
  </div>{%- comment %} end lgcy-panel-content--shop {% endcomment %}

  {%- comment %} ── Legacy content ── {% endcomment %}
  <div class="lgcy-panel-content lgcy-panel-content--legacy">
  <div class="lgcy-panel-nav lgcy-legacy-nav">
    <div class="lgcy-legacy-content">
      <p class="lgcy-legacy-eyebrow">The Inner Circle</p>
      <h2 class="lgcy-legacy-heading">Join The<br>Legacy.</h2>
      <p class="lgcy-legacy-sub">Be first. Get exclusive drops, early access to new collections, and member-only discounts — straight to your inbox.</p>

      <ul class="lgcy-legacy-perks">
        <li>Early access to every drop</li>
        <li>Member-only discounts</li>
        <li>Behind the scenes content</li>
        <li>Free shipping on first order</li>
      </ul>

      {%- form 'customer', id: 'lgcy-newsletter-form', class: 'lgcy-newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,legacy">
        <div class="lgcy-newsletter-row">
          <input
            type="email"
            name="contact[email]"
            class="lgcy-newsletter-input"
            placeholder="YOUR@EMAIL.COM"
            autocomplete="email"
            required
          >
          <button type="submit" class="lgcy-newsletter-btn">JOIN</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="lgcy-newsletter-success">You're in. Welcome to the Legacy.</p>
        {%- endif -%}
      {%- endform -%}

      <p class="lgcy-legacy-disclaimer">No spam. Unsubscribe anytime.</p>
    </div>
  </div>
  </div>{%- comment %} end lgcy-panel-content--legacy {% endcomment %}
</div>

<style>
  .lgcy-legacy-nav {
    justify-content: center !important;
    padding: 60px 40px !important;
  }

  .lgcy-legacy-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 360px;
  }

  .lgcy-legacy-eyebrow {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin: 0 0 14px;
  }

  .lgcy-legacy-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(38px, 6vw, 56px);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1;
    margin: 0 0 20px;
  }

  .lgcy-legacy-sub {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,0.55);
    margin: 0 0 24px;
    letter-spacing: 0;
  }

  .lgcy-legacy-perks {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .lgcy-legacy-perks li {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    padding-left: 16px;
    position: relative;
  }

  .lgcy-legacy-perks li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: rgba(255,255,255,0.4);
  }

  .lgcy-newsletter-form {
    width: 100%;
  }

  .lgcy-newsletter-row {
    display: flex;
    gap: 0;
    width: 100%;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .lgcy-newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 14px 16px;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #ffffff;
    text-transform: uppercase;
  }

  .lgcy-newsletter-input::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .lgcy-newsletter-btn {
    background: #ffffff;
    border: none;
    padding: 14px 20px;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000000;
    cursor: pointer;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  .lgcy-newsletter-btn:hover {
    background: rgba(255,255,255,0.85);
  }

  .lgcy-newsletter-success {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    margin: 12px 0 0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .lgcy-legacy-disclaimer {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 400;
    color: rgba(255,255,255,0.25);
    margin: 12px 0 0;
    letter-spacing: 0.04em;
  }
</style>

<script>
(function () {
  if (window.__lgcyShopMenuInit) return;
  window.__lgcyShopMenuInit = true;

  var shopBtn   = document.getElementById('lgcy-shop-btn');
  var legacyBtn = document.getElementById('lgcy-legacy-btn');
  var panel     = document.getElementById('lgcy-side-panel');
  var overlay   = document.getElementById('lgcy-menu-overlay');
  var closeBtn  = document.getElementById('lgcy-panel-close');
  var shopContent   = panel && panel.querySelector('.lgcy-panel-content--shop');
  var legacyContent = panel && panel.querySelector('.lgcy-panel-content--legacy');

  if (!shopBtn || !panel || !overlay) return;

  var pageContent = document.getElementById('page-content');
  if (pageContent && pageContent.parentNode) {
    pageContent.parentNode.insertBefore(overlay, pageContent.nextSibling);
    pageContent.parentNode.insertBefore(panel, pageContent.nextSibling);
  }

  var isOpen = false;
  var activeTab = 'shop';
  var hoverTimer;
  var mouseInPanel = false;
  var mouseInShopBtn = false;
  var mouseInLegacyBtn = false;

  function setTab(tab) {
    activeTab = tab;
    if (shopContent)   shopContent.classList.toggle('lgcy-active', tab === 'shop');
    if (legacyContent) legacyContent.classList.toggle('lgcy-active', tab === 'legacy');
    shopBtn.classList.toggle('lgcy-active', tab === 'shop');
    if (legacyBtn) legacyBtn.classList.toggle('lgcy-active', tab === 'legacy');
  }

  function openPanel(tab) {
    clearTimeout(hoverTimer);
    setTab(tab);
    if (isOpen) return;
    isOpen = true;
    panel.classList.add('lgcy-open');
    overlay.classList.add('lgcy-open');
    panel.setAttribute('aria-hidden', 'false');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.classList.add('lgcy-panel-open');
    document.body.style.overflow = 'hidden';
  }

  function closePanel() {
    clearTimeout(hoverTimer);
    if (!isOpen) return;
    isOpen = false;
    panel.classList.remove('lgcy-open');
    overlay.classList.remove('lgcy-open');
    panel.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('lgcy-panel-open');
    document.body.style.overflow = '';
    shopBtn.classList.remove('lgcy-active');
    if (legacyBtn) legacyBtn.classList.remove('lgcy-active');
  }

  function scheduleClose() {
    clearTimeout(hoverTimer);
    hoverTimer = setTimeout(function () {
      if (!mouseInShopBtn && !mouseInLegacyBtn && !mouseInPanel) closePanel();
    }, 200);
  }

  shopBtn.addEventListener('mouseenter', function () { mouseInShopBtn = true; openPanel('shop'); });
  shopBtn.addEventListener('mouseleave', function () { mouseInShopBtn = false; scheduleClose(); });
  shopBtn.addEventListener('click', function () { isOpen && activeTab === 'shop' ? closePanel() : openPanel('shop'); });

  if (legacyBtn) {
    legacyBtn.addEventListener('mouseenter', function () { mouseInLegacyBtn = true; openPanel('legacy'); });
    legacyBtn.addEventListener('mouseleave', function () { mouseInLegacyBtn = false; scheduleClose(); });
    legacyBtn.addEventListener('click', function () { isOpen && activeTab === 'legacy' ? closePanel() : openPanel('legacy'); });
  }

  panel.addEventListener('mouseenter', function () { mouseInPanel = true; clearTimeout(hoverTimer); });
  panel.addEventListener('mouseleave', function () { mouseInPanel = false; scheduleClose(); });

  if (closeBtn) closeBtn.addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && isOpen) closePanel(); });

  /* Move Shop trigger to front of Dawn nav */
  var inlineMenu  = document.querySelector('.header__inline-menu');
  var triggerWrap = document.getElementById('lgcy-shop-trigger-wrap');
  if (inlineMenu && triggerWrap) {
    inlineMenu.insertBefore(triggerWrap, inlineMenu.firstChild);
    triggerWrap.style.display = 'inline-flex';
  }

  /* Mobile: intercept hamburger to open lgcy panel instead of Dawn drawer */
  var hamburgerBtn = document.querySelector('.header__icon--menu');
  if (hamburgerBtn) {
    hamburgerBtn.addEventListener('click', function (e) {
      if (window.innerWidth > 989) return;
      e.preventDefault();
      e.stopImmediatePropagation();
      var drawerDetails = document.querySelector('header-drawer details');
      if (drawerDetails && drawerDetails.open) drawerDetails.removeAttribute('open');
      isOpen ? closePanel() : openPanel('shop');
    }, true);
  }
})();
</script>

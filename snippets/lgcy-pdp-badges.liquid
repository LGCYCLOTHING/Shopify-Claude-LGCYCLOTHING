{% comment %}
  LGCY — Product page badges:
    1. NEW pill next to the product title (every PDP)
    2. BLUE LIGHT FILTER pill at bottom-right of the gallery (tag-gated)
  Both injected via JS so we don't have to touch templates/product.json.
{% endcomment %}

{%- if template.name == 'product' and product -%}
<meta name="lgcy-product-tags" content="{{ product.tags | join: ',' | downcase | escape }}">

<style>
  /* === PDP info-panel — bumped text sizes for readability (all products) === */
  .rp-title {
    font-size: 22px !important;
    line-height: 1.2 !important;
  }
  .rp-price {
    font-size: 19px !important;
  }
  .rp-color-label,
  .rp-color-val {
    font-size: 13px !important;
  }
  .rp-size-label,
  .rp-size-guide,
  .rp-size-nis {
    font-size: 13px !important;
  }
  .rp-usp-text {
    font-size: 12px !important;
  }
  .rp-section-label {
    font-size: 13px !important;
  }
  .rp-acc-trigger {
    font-size: 14px !important;
    padding: 18px 0 !important;
  }
  .rp-acc-body-inner {
    font-size: 15px !important;
    line-height: 1.7 !important;
  }
  .rp-trigger-icon {
    font-size: 24px !important;
  }
  /* Notify When Available + breadcrumb inside info column */
  .rp-info a[href*="notify"],
  .rp-info .rp-notify,
  .rp-info .rp-bread,
  .rp-info .lgcy-breadcrumb,
  .rp-info nav {
    font-size: 13px !important;
  }

  @media (max-width: 749px) {
    .rp-title {
      font-size: 20px !important;
    }
    .rp-price {
      font-size: 17px !important;
    }
    .rp-acc-trigger {
      font-size: 13px !important;
      padding: 16px 0 !important;
    }
    .rp-acc-body-inner {
      font-size: 14px !important;
    }
  }

  /* === Kill the empty gap below the product image area === */
  /* The actual culprit was Shopify's section padding on the custom_liquid
     wrapper (padding-bottom: 52px). Templates JSON is in the deploy ignore
     list so we zero it from CSS instead. */
  [class*="custom_liquid_NQgBBj-padding"] {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  .rp-wrap {
    min-height: 0 !important;
    align-items: stretch !important;
  }
  .rp-info {
    min-height: 0 !important;
    align-items: flex-start !important;
    padding-bottom: 60px !important;
  }
  .rp-gallery {
    height: auto !important;
    min-height: 100vh !important;
  }
  .rp-editorial {
    margin-top: 0 !important;
  }
</style>

<style>
  /* === All PDPs — turn the first ("Product Details") accordion into a
        permanently-open, shaded info box. Other accordions untouched. === */

  /* Hide the trigger header for Product Details (first trigger) */
  .rp-acc-list > .rp-acc-trigger:first-of-type {
    display: none !important;
  }

  /* Force the Product Details body permanently open */
  #rp-acc-details {
    max-height: none !important;
    overflow: visible !important;
    border-bottom: 0 !important;
    margin-top: 24px;
    border-radius: 10px;
    background: #f5f3ee;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: none !important;
  }
  #rp-acc-details .rp-acc-body-inner {
    padding: 22px 24px !important;
    color: #444;
  }
  #rp-acc-details .rp-acc-body-inner p {
    margin-bottom: 10px;
  }
  #rp-acc-details .rp-acc-body-inner p:last-child {
    margin-bottom: 0;
  }
  /* Strip the redundant close × inside the open box */
  #rp-acc-details .rp-acc-close {
    display: none !important;
  }

  /* Restore the top border on the next accordion since we hid the first
     trigger that owned it */
  .rp-acc-list > .rp-acc-trigger:nth-of-type(1) + .rp-acc-body + .rp-acc-trigger {
    border-top: 1px solid #e0e0e0;
    margin-top: 24px;
  }

  @media (max-width: 749px) {
    #rp-acc-details {
      margin-top: 18px;
      border-radius: 8px;
    }
    #rp-acc-details .rp-acc-body-inner {
      padding: 18px 18px !important;
    }
  }
</style>

<template id="lgcy-pdp-new-template">
  <span class="lgcy-pdp-new-badge" role="note" aria-label="New product">NEW</span>
</template>

<template id="lgcy-pdp-bluelight-template">
  <span class="lgcy-pdp-bluelight-badge" role="note" aria-label="Blue light filter lens">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="3.5"/>
      <path d="M12 2v2"/>
      <path d="M12 20v2"/>
      <path d="m4.93 4.93 1.41 1.41"/>
      <path d="m17.66 17.66 1.41 1.41"/>
      <path d="M2 12h2"/>
      <path d="M20 12h2"/>
      <path d="m4.93 19.07 1.41-1.41"/>
      <path d="m17.66 6.34 1.41-1.41"/>
    </svg>
    <span>Blue Light Filter</span>
  </span>
</template>

<style>
  /* === NEW badge — next to product title === */
  .lgcy-pdp-new-badge {
    --border-width: 1px;
    position: relative;
    display: inline-flex;
    align-items: center;
    isolation: isolate;
    margin-left: 10px;
    padding: 5px 10px;
    border-radius: 6px;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-weight: 900;
    font-size: 10px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #000;
    background: linear-gradient(
      -75deg,
      rgba(255, 255, 255, 0.55),
      rgba(255, 255, 255, 0.85),
      rgba(255, 255, 255, 0.55)
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 0.2em 0.4em -0.1em rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(0, 0, 0, 0.08);
    -webkit-backdrop-filter: blur(6px) saturate(140%);
            backdrop-filter: blur(6px) saturate(140%);
    line-height: 1;
    vertical-align: middle;
    white-space: nowrap;
  }
  .lgcy-pdp-new-badge::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 6px;
    width: calc(100% + var(--border-width));
    height: calc(100% + var(--border-width));
    top: calc(0% - var(--border-width) / 2);
    left: calc(0% - var(--border-width) / 2);
    padding: var(--border-width);
    box-sizing: border-box;
    background: conic-gradient(
      from -75deg at 50% 50%,
      rgba(0, 0, 0, 0.4),
      rgba(0, 0, 0, 0) 5% 40%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0) 60% 95%,
      rgba(0, 0, 0, 0.4)
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  /* === BLUE LIGHT FILTER badge — bottom-right of gallery === */
  .lgcy-pdp-bluelight-badge {
    --border-width: 1px;
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 14;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    isolation: isolate;
    padding: 9px 14px;
    border-radius: 10px;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-weight: 900;
    font-size: 11px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #0a3a6b;
    background: linear-gradient(
      -75deg,
      rgba(200, 222, 245, 0.6),
      rgba(225, 238, 252, 0.88),
      rgba(200, 222, 245, 0.6)
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(20, 60, 110, 0.15),
      0 0.3em 0.7em -0.15em rgba(20, 60, 110, 0.25),
      0 0 0 1px rgba(20, 60, 110, 0.08);
    -webkit-backdrop-filter: blur(10px) saturate(150%);
            backdrop-filter: blur(10px) saturate(150%);
    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 360ms cubic-bezier(0.4, 0, 0.2, 1),
                transform 360ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .lgcy-pdp-bluelight-badge.is-shown {
    opacity: 1;
    transform: translateY(0);
  }
  .lgcy-pdp-bluelight-badge::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 10px;
    width: calc(100% + var(--border-width));
    height: calc(100% + var(--border-width));
    top: calc(0% - var(--border-width) / 2);
    left: calc(0% - var(--border-width) / 2);
    padding: var(--border-width);
    box-sizing: border-box;
    background: conic-gradient(
      from -75deg at 50% 50%,
      rgba(20, 60, 110, 0.45),
      rgba(20, 60, 110, 0) 5% 40%,
      rgba(20, 60, 110, 0.45) 50%,
      rgba(20, 60, 110, 0) 60% 95%,
      rgba(20, 60, 110, 0.45)
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  .lgcy-pdp-bluelight-badge svg {
    color: #0a3a6b;
    flex-shrink: 0;
  }

  @media (max-width: 749px) {
    .lgcy-pdp-new-badge {
      font-size: 9px;
      margin-left: 8px;
      padding: 4px 8px;
    }
    .lgcy-pdp-bluelight-badge {
      bottom: 12px;
      right: 12px;
      padding: 7px 11px;
      font-size: 10px;
      border-radius: 8px;
    }
    .lgcy-pdp-bluelight-badge::after {
      border-radius: 8px;
    }
  }
</style>

<script>
  (function () {
    var tagsMeta = document.querySelector('meta[name="lgcy-product-tags"]');
    var tags = tagsMeta ? (tagsMeta.getAttribute('content') || '').split(',').map(function (t) {
      return t.trim().toLowerCase();
    }) : [];
    var isBlueLight = tags.indexOf('blue-light') !== -1 ||
                      tags.indexOf('bluelight') !== -1 ||
                      tags.indexOf('blue light') !== -1;

    var newTpl = document.getElementById('lgcy-pdp-new-template');
    var blTpl  = document.getElementById('lgcy-pdp-bluelight-template');

    var TITLE_SELECTORS = ['.rp-title', '.product__title', 'h1.product-title', 'h1[itemprop="name"]'];
    var GALLERY_SELECTORS = ['.rp-gallery', '.product__media-wrapper', '.product__media-list', 'media-gallery', '.product-media-container'];

    function findFirst(sels) {
      for (var i = 0; i < sels.length; i++) {
        var el = document.querySelector(sels[i]);
        if (el) return el;
      }
      return null;
    }

    function injectNewBadge() {
      if (document.querySelector('.lgcy-pdp-new-badge')) return true;
      var title = findFirst(TITLE_SELECTORS);
      if (!title || !newTpl) return false;
      var badge = newTpl.content.firstElementChild.cloneNode(true);
      /* Insert AFTER the title element (not inside it) so dynamic
         breadcrumbs reading h1.textContent don't pick up "NEW". */
      if (title.parentNode) {
        title.parentNode.insertBefore(badge, title.nextSibling);
      } else {
        title.appendChild(badge);
      }
      return true;
    }

    function injectBlueLight() {
      if (!isBlueLight) return true;
      if (document.querySelector('.lgcy-pdp-bluelight-badge')) return true;
      var host = findFirst(GALLERY_SELECTORS);
      if (!host || !blTpl) return false;
      if (getComputedStyle(host).position === 'static') {
        host.style.position = 'relative';
      }
      var badge = blTpl.content.firstElementChild.cloneNode(true);
      host.appendChild(badge);
      requestAnimationFrame(function () { badge.classList.add('is-shown'); });
      return true;
    }

    function tick() {
      var a = injectNewBadge();
      var b = injectBlueLight();
      return a && b;
    }

    if (tick()) return;
    var tries = 0;
    var t = setInterval(function () {
      tries++;
      if (tick() || tries >= 30) clearInterval(t);
    }, 250);
  })();
</script>
{%- endif -%}

{% comment %}
  LGCY — Product page badges:
    1. NEW pill next to the product title (every PDP)
    2. BLUE LIGHT FILTER pill at bottom-right of the gallery (tag-gated)
  Both injected via JS so we don't have to touch templates/product.json.
{% endcomment %}

{%- if template.name == 'product' and product -%}
<meta name="lgcy-product-tags" content="{{ product.tags | join: ',' | downcase | escape }}">
<meta name="lgcy-product-handle" content="{{ product.handle | escape }}">

{%- comment -%} Detect eyewear by collection / type / tag {%- endcomment -%}
{%- assign is_eyewear = false -%}
{%- for col in product.collections -%}
  {%- assign ch = col.handle | downcase -%}
  {%- if ch contains 'glass' or ch contains 'eyewear' or ch contains 'sunglass' -%}{%- assign is_eyewear = true -%}{%- endif -%}
{%- endfor -%}
{%- assign pt = product.type | downcase -%}
{%- if pt contains 'glass' or pt contains 'eyewear' or pt contains 'sunglass' -%}{%- assign is_eyewear = true -%}{%- endif -%}
{%- for t in product.tags -%}
  {%- assign tl = t | downcase -%}
  {%- if tl == 'eyewear' or tl == 'glasses' or tl == 'sunglasses' -%}{%- assign is_eyewear = true -%}{%- endif -%}
{%- endfor -%}
{%- if is_eyewear -%}
  <meta name="lgcy-product-is-eyewear" content="1">
{%- endif -%}

<style>
  /* === PDP info-panel — bumped text sizes for readability (all products) === */
  .rp-title {
    font-size: 22px !important;
    line-height: 1.2 !important;
  }
  .rp-price {
    font-size: 19px !important;
  }
  .rp-color-label,
  .rp-color-val {
    font-size: 13px !important;
  }
  .rp-size-label,
  .rp-size-guide,
  .rp-size-nis {
    font-size: 13px !important;
  }
  .rp-usp-text {
    font-size: 12px !important;
  }
  .rp-section-label {
    font-size: 13px !important;
  }
  .rp-acc-trigger {
    font-size: 14px !important;
    padding: 18px 0 !important;
  }
  .rp-acc-body-inner {
    font-size: 15px !important;
    line-height: 1.7 !important;
  }
  .rp-trigger-icon {
    font-size: 24px !important;
  }
  /* Notify When Available + breadcrumb inside info column */
  .rp-info a[href*="notify"],
  .rp-info .rp-notify,
  .rp-info .rp-bread,
  .rp-info .lgcy-breadcrumb,
  .rp-info nav {
    font-size: 13px !important;
  }

  @media (max-width: 749px) {
    .rp-title {
      font-size: 20px !important;
    }
    .rp-price {
      font-size: 17px !important;
    }
    .rp-acc-trigger {
      font-size: 13px !important;
      padding: 16px 0 !important;
    }
    .rp-acc-body-inner {
      font-size: 14px !important;
    }
  }

  /* === Kill the empty gap below the product image area === */
  /* The actual culprit was Shopify's section padding on the custom_liquid
     wrapper (padding-bottom: 52px). Templates JSON is in the deploy ignore
     list so we zero it from CSS instead. */
  [class*="custom_liquid_NQgBBj-padding"] {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  /* === PDP layout — fixed-height row; info column scrolls internally === */
  html, body {
    overflow-x: hidden;
  }
  .rp-wrap {
    height: 100vh !important;
    max-height: 100vh !important;
    min-height: 100vh !important;
    box-sizing: border-box !important;
    overflow: hidden !important;
    grid-template-columns: 1fr 1fr !important;
    align-items: stretch !important;
    /* Inset the right edge so the scrollbar sits next to the column
       content instead of at the very edge of the browser window. */
    padding-right: 56px !important;
  }
  .rp-gallery {
    height: 100vh !important;
    max-height: 100vh !important;
    overflow: hidden !important;
    position: relative !important;
  }
  .rp-info {
    display: block !important;
    height: 100vh !important;
    max-height: 100vh !important;
    min-height: 0 !important;
    box-sizing: border-box !important;
    overflow-y: scroll !important;
    overflow-x: hidden !important;
    overscroll-behavior: contain !important;
    -webkit-overflow-scrolling: touch;
    /* Top padding matches "LGCY.01" breathing room from top;
       bottom padding gives the last accordion room to scroll above the
       column's bottom edge. */
    padding: 60px 24px 100px 32px !important;
    align-items: unset !important;
    justify-content: unset !important;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.28) transparent;
  }
  .rp-info::-webkit-scrollbar {
    width: 7px;
  }
  .rp-info::-webkit-scrollbar-track {
    background: transparent;
  }
  .rp-info::-webkit-scrollbar-thumb {
    background: rgba(0,0,0,0.25);
    border-radius: 999vw;
  }
  .rp-info::-webkit-scrollbar-thumb:hover {
    background: rgba(0,0,0,0.45);
  }
  .rp-inner {
    max-width: 560px !important;
    width: 100% !important;
    margin: 0 auto !important;
    display: block !important;
  }

  /* Injected glasses accordions — open by default (matches existing behavior) */
  #rp-acc-dimensions,
  #rp-acc-framedetails,
  #rp-acc-carestorage {
    max-height: 2000px !important;
  }

  @media (max-width: 749px) {
    .rp-wrap {
      grid-template-columns: 1fr !important;
      height: auto !important;
      max-height: none !important;
      min-height: 0 !important;
      overflow: visible !important;
    }
    .rp-gallery,
    .rp-info {
      height: auto !important;
      max-height: none !important;
      overflow: visible !important;
      padding: 30px 20px !important;
    }
  }

  /* === Stock status pill — same liquid-glass design for all three states === */
  .rp-usp-row:has(.rp-dot-in),
  .rp-usp-row:has(.rp-dot-low),
  .rp-usp-row:has(.rp-dot-out) {
    position: relative;
    display: inline-flex !important;
    align-items: center;
    gap: 10px !important;
    padding: 9px 16px 9px 14px !important;
    width: fit-content !important;
    border-radius: 999vw !important;
    isolation: isolate;
    -webkit-backdrop-filter: blur(8px) saturate(140%);
            backdrop-filter: blur(8px) saturate(140%);
  }
  /* In stock — green tint */
  .rp-usp-row:has(.rp-dot-in) {
    background: linear-gradient(-75deg,
      rgba(34, 197, 94, 0.10),
      rgba(34, 197, 94, 0.22),
      rgba(34, 197, 94, 0.10));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      inset 0 -1px 0 rgba(22, 130, 60, 0.18),
      0 0.25em 0.5em -0.125em rgba(22, 130, 60, 0.18),
      0 0 0 1px rgba(22, 130, 60, 0.20);
  }
  /* Limited — orange tint */
  .rp-usp-row:has(.rp-dot-low) {
    background: linear-gradient(-75deg,
      rgba(246, 118, 55, 0.10),
      rgba(246, 118, 55, 0.22),
      rgba(246, 118, 55, 0.10));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      inset 0 -1px 0 rgba(178, 80, 34, 0.18),
      0 0.25em 0.5em -0.125em rgba(178, 80, 34, 0.18),
      0 0 0 1px rgba(178, 80, 34, 0.18);
  }
  /* Out of stock — red tint */
  .rp-usp-row:has(.rp-dot-out) {
    background: linear-gradient(-75deg,
      rgba(239, 68, 68, 0.10),
      rgba(239, 68, 68, 0.22),
      rgba(239, 68, 68, 0.10));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      inset 0 -1px 0 rgba(180, 40, 40, 0.20),
      0 0.25em 0.5em -0.125em rgba(180, 40, 40, 0.20),
      0 0 0 1px rgba(180, 40, 40, 0.20);
  }
  .rp-usp-row:has(.rp-dot-in) .rp-usp-text,
  .rp-usp-row:has(.rp-dot-low) .rp-usp-text,
  .rp-usp-row:has(.rp-dot-out) .rp-usp-text {
    font-size: 12px !important;
    font-weight: 900 !important;
    letter-spacing: -0.02em !important;
    color: #1a1a1a !important;
    text-transform: uppercase !important;
  }
  .rp-usp-row:has(.rp-dot-in) .rp-dot-in,
  .rp-usp-row:has(.rp-dot-low) .rp-dot-low,
  .rp-usp-row:has(.rp-dot-out) .rp-dot-out {
    width: 9px !important;
    height: 9px !important;
  }
  .rp-usp-row:has(.rp-dot-in) .rp-dot-in::before,
  .rp-usp-row:has(.rp-dot-low) .rp-dot-low::before,
  .rp-usp-row:has(.rp-dot-out) .rp-dot-out::before {
    width: 9px !important;
    height: 9px !important;
  }
  .rp-editorial {
    margin-top: 0 !important;
  }
</style>

<style>
  /* === All PDPs — turn the first ("Product Details") accordion into a
        permanently-open, shaded info box. Other accordions untouched. === */

  /* Hide the trigger header for Product Details (first trigger) */
  .rp-acc-list > .rp-acc-trigger:first-of-type {
    display: none !important;
  }

  /* Force the Product Details body permanently open */
  #rp-acc-details {
    max-height: none !important;
    overflow: visible !important;
    border-bottom: 0 !important;
    margin-top: 24px;
    border-radius: 10px;
    background: #f5f3ee;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: none !important;
  }
  #rp-acc-details .rp-acc-body-inner {
    padding: 22px 24px !important;
    color: #444;
  }
  #rp-acc-details .rp-acc-body-inner p {
    margin-bottom: 10px;
  }
  #rp-acc-details .rp-acc-body-inner p:last-child {
    margin-bottom: 0;
  }
  /* Strip the redundant close × inside the open box */
  #rp-acc-details .rp-acc-close {
    display: none !important;
  }

  /* Restore the top border on the next accordion since we hid the first
     trigger that owned it */
  .rp-acc-list > .rp-acc-trigger:nth-of-type(1) + .rp-acc-body + .rp-acc-trigger {
    border-top: 1px solid #e0e0e0;
    margin-top: 24px;
  }

  @media (max-width: 749px) {
    #rp-acc-details {
      margin-top: 18px;
      border-radius: 8px;
    }
    #rp-acc-details .rp-acc-body-inner {
      padding: 18px 18px !important;
    }
  }
</style>

<template id="lgcy-pdp-new-template">
  <span class="lgcy-pdp-new-badge" role="note" aria-label="New product">NEW</span>
</template>

<template id="lgcy-pdp-bluelight-template">
  <span class="lgcy-pdp-bluelight-badge" role="note" aria-label="Blue light filter lens">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="3.5"/>
      <path d="M12 2v2"/>
      <path d="M12 20v2"/>
      <path d="m4.93 4.93 1.41 1.41"/>
      <path d="m17.66 17.66 1.41 1.41"/>
      <path d="M2 12h2"/>
      <path d="M20 12h2"/>
      <path d="m4.93 19.07 1.41-1.41"/>
      <path d="m17.66 6.34 1.41-1.41"/>
    </svg>
    <span>Blue Light Filter</span>
  </span>
</template>

<style>
  /* === NEW badge — next to product title === */
  .lgcy-pdp-new-badge {
    --border-width: 1px;
    position: relative;
    display: inline-flex;
    align-items: center;
    isolation: isolate;
    margin-left: 10px;
    padding: 5px 10px;
    border-radius: 6px;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-weight: 900;
    font-size: 10px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #000;
    background: linear-gradient(
      -75deg,
      rgba(255, 255, 255, 0.55),
      rgba(255, 255, 255, 0.85),
      rgba(255, 255, 255, 0.55)
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 0.2em 0.4em -0.1em rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(0, 0, 0, 0.08);
    -webkit-backdrop-filter: blur(6px) saturate(140%);
            backdrop-filter: blur(6px) saturate(140%);
    line-height: 1;
    vertical-align: middle;
    white-space: nowrap;
  }
  .lgcy-pdp-new-badge::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 6px;
    width: calc(100% + var(--border-width));
    height: calc(100% + var(--border-width));
    top: calc(0% - var(--border-width) / 2);
    left: calc(0% - var(--border-width) / 2);
    padding: var(--border-width);
    box-sizing: border-box;
    background: conic-gradient(
      from -75deg at 50% 50%,
      rgba(0, 0, 0, 0.4),
      rgba(0, 0, 0, 0) 5% 40%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0) 60% 95%,
      rgba(0, 0, 0, 0.4)
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  /* === BLUE LIGHT FILTER badge — bottom-right of gallery === */
  .lgcy-pdp-bluelight-badge {
    --border-width: 1px;
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 14;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    isolation: isolate;
    padding: 9px 14px;
    border-radius: 10px;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-weight: 900;
    font-size: 11px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #0a3a6b;
    background: linear-gradient(
      -75deg,
      rgba(200, 222, 245, 0.6),
      rgba(225, 238, 252, 0.88),
      rgba(200, 222, 245, 0.6)
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(20, 60, 110, 0.15),
      0 0.3em 0.7em -0.15em rgba(20, 60, 110, 0.25),
      0 0 0 1px rgba(20, 60, 110, 0.08);
    -webkit-backdrop-filter: blur(10px) saturate(150%);
            backdrop-filter: blur(10px) saturate(150%);
    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 360ms cubic-bezier(0.4, 0, 0.2, 1),
                transform 360ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .lgcy-pdp-bluelight-badge.is-shown {
    opacity: 1;
    transform: translateY(0);
  }
  .lgcy-pdp-bluelight-badge::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 10px;
    width: calc(100% + var(--border-width));
    height: calc(100% + var(--border-width));
    top: calc(0% - var(--border-width) / 2);
    left: calc(0% - var(--border-width) / 2);
    padding: var(--border-width);
    box-sizing: border-box;
    background: conic-gradient(
      from -75deg at 50% 50%,
      rgba(20, 60, 110, 0.45),
      rgba(20, 60, 110, 0) 5% 40%,
      rgba(20, 60, 110, 0.45) 50%,
      rgba(20, 60, 110, 0) 60% 95%,
      rgba(20, 60, 110, 0.45)
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  .lgcy-pdp-bluelight-badge svg {
    color: #0a3a6b;
    flex-shrink: 0;
  }

  @media (max-width: 749px) {
    .lgcy-pdp-new-badge {
      font-size: 9px;
      margin-left: 8px;
      padding: 4px 8px;
    }
    .lgcy-pdp-bluelight-badge {
      bottom: 12px;
      right: 12px;
      padding: 7px 11px;
      font-size: 10px;
      border-radius: 8px;
    }
    .lgcy-pdp-bluelight-badge::after {
      border-radius: 8px;
    }
  }
</style>

<script>
  (function () {
    var tagsMeta = document.querySelector('meta[name="lgcy-product-tags"]');
    var tags = tagsMeta ? (tagsMeta.getAttribute('content') || '').split(',').map(function (t) {
      return t.trim().toLowerCase();
    }) : [];
    var isBlueLight = tags.indexOf('blue-light') !== -1 ||
                      tags.indexOf('bluelight') !== -1 ||
                      tags.indexOf('blue light') !== -1;

    var newTpl = document.getElementById('lgcy-pdp-new-template');
    var blTpl  = document.getElementById('lgcy-pdp-bluelight-template');

    var TITLE_SELECTORS = ['.rp-title', '.product__title', 'h1.product-title', 'h1[itemprop="name"]'];
    var GALLERY_SELECTORS = ['.rp-gallery', '.product__media-wrapper', '.product__media-list', 'media-gallery', '.product-media-container'];

    function findFirst(sels) {
      for (var i = 0; i < sels.length; i++) {
        var el = document.querySelector(sels[i]);
        if (el) return el;
      }
      return null;
    }

    function injectNewBadge() {
      if (document.querySelector('.lgcy-pdp-new-badge')) return true;
      var title = findFirst(TITLE_SELECTORS);
      if (!title || !newTpl) return false;
      var badge = newTpl.content.firstElementChild.cloneNode(true);
      /* Insert AFTER the title element (not inside it) so dynamic
         breadcrumbs reading h1.textContent don't pick up "NEW". */
      if (title.parentNode) {
        title.parentNode.insertBefore(badge, title.nextSibling);
      } else {
        title.appendChild(badge);
      }
      return true;
    }

    function injectBlueLight() {
      if (!isBlueLight) return true;
      if (document.querySelector('.lgcy-pdp-bluelight-badge')) return true;
      var host = findFirst(GALLERY_SELECTORS);
      if (!host || !blTpl) return false;
      if (getComputedStyle(host).position === 'static') {
        host.style.position = 'relative';
      }
      var badge = blTpl.content.firstElementChild.cloneNode(true);
      host.appendChild(badge);
      requestAnimationFrame(function () { badge.classList.add('is-shown'); });
      return true;
    }

    function tick() {
      var a = injectNewBadge();
      var b = injectBlueLight();
      return a && b;
    }

    if (tick()) return;
    var tries = 0;
    var t = setInterval(function () {
      tries++;
      if (tick() || tries >= 30) clearInterval(t);
    }, 250);
  })();
</script>

{%- comment -%} === GLASSES PDP — swap Size Chart + Care for Dimensions / Frame / Care & Storage === {%- endcomment -%}
<style>
  /* Hide existing Size Chart + Care Instructions on eyewear pages */
  html[data-lgcy-eyewear] button[onclick*="'sizechart'"],
  html[data-lgcy-eyewear] #rp-acc-sizechart,
  html[data-lgcy-eyewear] button[onclick*="'care'"]:not([onclick*="'carestorage'"]),
  html[data-lgcy-eyewear] #rp-acc-care:not(#rp-acc-carestorage) {
    display: none !important;
  }

  /* Dimensions / Frame Details tables */
  .lgcy-spec-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .lgcy-spec-list li {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 14px;
  }
  .lgcy-spec-list li:last-child {
    border-bottom: 0;
  }
  .lgcy-spec-list li .lgcy-spec-key {
    color: #666;
    letter-spacing: -0.01em;
  }
  .lgcy-spec-list li .lgcy-spec-val {
    font-weight: 800;
    color: #111;
    letter-spacing: -0.02em;
  }
</style>

<script>
  (function () {
    var eyewearMeta = document.querySelector('meta[name="lgcy-product-is-eyewear"]');
    if (!eyewearMeta) return;
    document.documentElement.setAttribute('data-lgcy-eyewear', '1');

    var handleMeta = document.querySelector('meta[name="lgcy-product-handle"]');
    var handle = handleMeta ? handleMeta.getAttribute('content') : '';

    /* Per-product specs. Add more handles here as new frames launch. */
    var GLASSES_DATA = {
      'lgcy-01-aeris-black-clear': {
        dimensions: [
          ['Temple Length', '145mm'],
          ['Frame Width', '133.2mm'],
          ['Lens Width', '47mm'],
          ['Lens Height', '39.8mm']
        ],
        frame: [
          ['Silhouette', 'Round'],
          ['Material', 'Premium acetate'],
          ['Bridge', '20mm'],
          ['Lens', 'Optical-grade clear · blue-light filter']
        ]
      },
      'lgcy-01-aeris-black-purple': {
        dimensions: [
          ['Temple Length', '145mm'],
          ['Frame Width', '133.2mm'],
          ['Lens Width', '47mm'],
          ['Lens Height', '39.8mm']
        ],
        frame: [
          ['Silhouette', 'Round'],
          ['Material', 'Premium acetate'],
          ['Bridge', '20mm'],
          ['Lens', 'Tinted purple']
        ]
      }
    };

    /* Care copy — slightly different wording from any common reference. */
    var CARE_HTML =
      '<p>Each pair ships in a hard case with a microfiber cloth. ' +
      'Keep your frames inside the case whenever they\'re not on your face.</p>' +
      '<p>Wipe lenses gently with the cloth — never use paper, alcohol, ' +
      'or household cleaners. They will scratch coatings and break down the acetate.</p>' +
      '<p>Avoid leaving your glasses in direct sun for long stretches ' +
      '(parked cars, dashboards) — sustained heat warps the frame.</p>';

    function buildList(rows) {
      var html = '<ul class="lgcy-spec-list">';
      rows.forEach(function (r) {
        html += '<li><span class="lgcy-spec-key">' + r[0] +
                '</span><span class="lgcy-spec-val">' + r[1] + '</span></li>';
      });
      html += '</ul>';
      return html;
    }

    function init() {
      var list = document.querySelector('.rp-acc-list');
      if (!list) return false;
      if (document.getElementById('rp-acc-dimensions')) return true;

      var data = GLASSES_DATA[handle] || null;
      var dimHtml, frameHtml;
      if (data) {
        dimHtml = buildList(data.dimensions);
        frameHtml = buildList(data.frame);
      } else {
        dimHtml = '<p style="color:#666;">Dimensions for this frame are coming soon.</p>';
        frameHtml = '<p style="color:#666;">Frame details for this style are coming soon.</p>';
      }

      var accordions = [
        { id: 'dimensions',  title: 'Dimensions',     body: dimHtml },
        { id: 'framedetails', title: 'Frame Details',  body: frameHtml },
        { id: 'carestorage', title: 'Care &amp; Storage', body: CARE_HTML }
      ];

      accordions.forEach(function (acc) {
        var btn = document.createElement('button');
        btn.className = 'rp-acc-trigger open';
        btn.type = 'button';
        btn.setAttribute('onclick', "rpAccToggle('" + acc.id + "', this)");
        btn.innerHTML = acc.title + '<span class="rp-trigger-icon">+</span>';

        var body = document.createElement('div');
        body.className = 'rp-acc-body';
        body.id = 'rp-acc-' + acc.id;
        body.style.maxHeight = '2000px';
        body.innerHTML = '<div class="rp-acc-body-inner">' + acc.body + '</div>';

        list.appendChild(btn);
        list.appendChild(body);
      });

      /* Move Shipping & Returns to the very bottom (after the new accordions) */
      var shippingBtn = list.querySelector('button[onclick*="shipping"]');
      var shippingBody = list.querySelector('#rp-acc-shipping');
      if (shippingBtn) list.appendChild(shippingBtn);
      if (shippingBody) list.appendChild(shippingBody);

      /* Auto-open the new accordions (matches the existing "open all" behavior) */
      setTimeout(function () {
        list.querySelectorAll('.rp-acc-trigger').forEach(function (t) {
          if (!t.classList.contains('open') && t.style.display !== 'none') {
            try { t.click(); } catch (e) {}
          }
        });
      }, 50);

      return true;
    }

    if (init()) return;
    var tries = 0;
    var t = setInterval(function () {
      tries++;
      if (init() || tries >= 40) clearInterval(t);
    }, 250);
  })();
</script>
{%- endif -%}

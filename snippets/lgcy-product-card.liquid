{% comment %}
  LGCYCLOTHING — Product Card Snippet
  Save as: snippets/lgcy-product-card.liquid
{% endcomment %}

<style>
  .lgcy-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: transparent;
    cursor: pointer;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .lgcy-card__image-wrap {
    position: relative;
    overflow: hidden;
    background: #f7f7f7;
    aspect-ratio: 3 / 4;
    width: 100%;
  }

  .lgcy-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .lgcy-card__image--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .lgcy-card:hover .lgcy-card__image--hover {
    opacity: 1;
  }

  /* Size panel — hidden by default, controlled by JS */
  .lgcy-card__quick-add {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    background: transparent;
    transform: translateY(100%);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 12px 10px 14px;
  }

  .lgcy-card__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    justify-content: center;
  }

  .lgcy-card__size-btn {
    flex-shrink: 0;
    min-width: 38px;
    height: 38px;
    padding: 0 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-family: inherit;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    outline: 1px solid rgba(255,255,255,0.8);
    background: rgba(255,255,255,0.85);
    color: #000 !important;
    border: none;
    cursor: pointer;
    transition: outline-color 0.15s ease, background 0.15s ease;
    -webkit-tap-highlight-color: transparent;
    -webkit-text-fill-color: #000;
  }

  .lgcy-card__size-btn:hover {
    background: #fff;
    outline: 1px solid #000;
    outline-offset: -1px;
    z-index: 1;
  }

  .lgcy-card__size-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .lgcy-card__size-btn.lgcy-adding {
    background: #000;
    color: #fff;
    outline-color: #000;
  }

  /* "NEW" badge — liquid glass pill, top-left of image */
  .lgcy-card__new-badge {
    --border-width: 1px;
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 12;
    display: inline-flex;
    align-items: center;
    isolation: isolate;
    padding: 6px 12px;
    border-radius: 999vw;
    font-family: 'Inter', Helvetica, Arial, sans-serif;
    font-weight: 900;
    font-size: 10px;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #000;
    background: linear-gradient(
      -75deg,
      rgba(255, 255, 255, 0.55),
      rgba(255, 255, 255, 0.85),
      rgba(255, 255, 255, 0.55)
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 0.25em 0.5em -0.125em rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(0, 0, 0, 0.06);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
            backdrop-filter: blur(8px) saturate(140%);
    pointer-events: none;
  }
  /* Conic-gradient outline ring — same recipe as the other glass elements */
  .lgcy-card__new-badge::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: 999vw;
    width: calc(100% + var(--border-width));
    height: calc(100% + var(--border-width));
    top: calc(0% - var(--border-width) / 2);
    left: calc(0% - var(--border-width) / 2);
    padding: var(--border-width);
    box-sizing: border-box;
    background: conic-gradient(
      from -75deg at 50% 50%,
      rgba(0, 0, 0, 0.4),
      rgba(0, 0, 0, 0) 5% 40%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0) 60% 95%,
      rgba(0, 0, 0, 0.4)
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }

  /* Plus button — transparent bg, black icon */
  .lgcy-card__plus-btn {
    position: absolute;
    bottom: 10px;
    right: 10px;
    z-index: 11;
    width: 30px;
    height: 30px;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    opacity: 1;
    transition: opacity 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .lgcy-card__plus-btn {
    color: #000;
  }

  .lgcy-card__plus-btn svg {
    width: 14px;
    height: 14px;
    stroke: #000 !important;
  }

  /* JS-controlled hidden state for the plus button */
  .lgcy-card__plus-btn.lgcy-plus--hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* Toggle between + and × icons */
  .lgcy-close-icon { display: none; }
  .lgcy-card__plus-btn.lgcy-panel-open .lgcy-plus-icon { display: none; }
  .lgcy-card__plus-btn.lgcy-panel-open .lgcy-close-icon { display: block; }

  /* Mobile: size row scrolls horizontally */
  @media (hover: none) and (pointer: coarse) {
    .lgcy-card__sizes {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .lgcy-card__sizes::-webkit-scrollbar {
      display: none;
    }
  }

  /* Card footer */
  .lgcy-card__footer {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 0 0;
  }

  @media (min-width: 768px) {
    .lgcy-card__footer {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      padding: 14px 0 10px;
    }
  }

  .lgcy-card__meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .lgcy-card__title {
    font-family: inherit;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    color: #000;
    line-height: 1.3;
  }

  .lgcy-card__color {
    font-family: inherit;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #888;
    text-transform: capitalize;
    line-height: 1.3;
  }

  .lgcy-card__color-count {
    margin-left: 4px;
    color: #aaa;
  }

  .lgcy-card__price {
    font-family: inherit;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    white-space: nowrap;
    padding-top: 2px;
  }

  .lgcy-card__price--sale { color: #c62f2f; }

  .lgcy-card__price--compare {
    color: #aaa;
    text-decoration: line-through;
    margin-right: 5px;
  }

  /* Toast */
  .lgcy-cart-toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #000;
    color: #fff;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 10px 20px;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .lgcy-cart-toast.lgcy-toast--show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

{%- liquid
  assign product_title = product.title
  assign product_url   = product.url
  assign featured_img  = product.featured_media
  assign hover_img     = product.media[1]
  assign price         = product.price
  assign compare_price = product.compare_at_price
  assign on_sale       = false
  if compare_price > price
    assign on_sale = true
  endif
  assign color_option = ''
  assign color_count  = 0
  for option in product.options_with_values
    if option.name == 'Color' or option.name == 'Colour'
      assign color_option = option.values | first
      assign color_count  = option.values.size
    endif
  endfor
  assign size_option_index = nil
  for option in product.options_with_values
    if option.name == 'Size' or option.name == 'size'
      assign size_option_index = forloop.index0
    endif
  endfor
  assign has_sizes = false
  if product.variants.size > 1
    assign has_sizes = true
  elsif product.variants.size == 1 and product.variants.first.title != 'Default Title'
    assign has_sizes = true
  endif
  assign single_variant_id = ''
  unless has_sizes
    assign single_variant_id = product.variants.first.id | append: ''
  endunless
-%}

<a
  href="{{ product_url }}"
  class="lgcy-card"
  data-product-id="{{ product.id }}"
  aria-label="{{ product_title | escape }}"
>
  <div class="lgcy-card__image-wrap" data-quick-add-wrap>

    {%- if product.tags contains 'new' or product.tags contains 'New' or product.tags contains 'NEW' -%}
      <span class="lgcy-card__new-badge" aria-label="New product">NEW</span>
    {%- endif -%}

    {%- if featured_img -%}
      <img
        src="{{ featured_img | image_url: width: 800 }}"
        alt="{{ featured_img.alt | escape | default: product_title }}"
        width="{{ featured_img.preview_image.width }}"
        height="{{ featured_img.preview_image.height }}"
        loading="{{ lazy | default: 'lazy' }}"
        class="lgcy-card__image"
      >
    {%- endif -%}

    {%- if hover_img -%}
      <img
        src="{{ hover_img | image_url: width: 800 }}"
        alt="{{ hover_img.alt | escape | default: product_title }}"
        width="{{ hover_img.preview_image.width }}"
        height="{{ hover_img.preview_image.height }}"
        loading="lazy"
        class="lgcy-card__image lgcy-card__image--hover"
      >
    {%- endif -%}

    <button
      type="button"
      class="lgcy-card__plus-btn"
      data-plus-btn
      {% unless has_sizes %}data-single-variant="{{ single_variant_id }}"{% endunless %}
      aria-label="Quick add {{ product_title | escape }}"
    >
      <svg class="lgcy-plus-icon" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="14" height="14">
        <path d="M7 1v12M1 7h12" stroke-width="1.5" stroke-linecap="round" stroke="currentColor"/>
      </svg>
      <svg class="lgcy-close-icon" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="14" height="14">
        <path d="M1 1l12 12M13 1L1 13" stroke-width="1.5" stroke-linecap="round" stroke="currentColor"/>
      </svg>
    </button>

    {%- if has_sizes -%}
      <div class="lgcy-card__quick-add" data-quick-add-panel>
        <div class="lgcy-card__sizes">
          {%- for variant in product.variants -%}
            {%- if size_option_index == 0 -%}
              {%- assign size_label = variant.option1 -%}
            {%- elsif size_option_index == 1 -%}
              {%- assign size_label = variant.option2 -%}
            {%- elsif size_option_index == 2 -%}
              {%- assign size_label = variant.option3 -%}
            {%- else -%}
              {%- assign size_label = variant.title | split: ' / ' | first -%}
            {%- endif -%}
            <button
              type="button"
              class="lgcy-card__size-btn"
              data-variant-id="{{ variant.id }}"
              {% unless variant.available %}disabled{% endunless %}
              aria-label="Add {{ size_label | escape }} to cart"
            >
              {{- size_label -}}
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>

  <div class="lgcy-card__footer">
    <div class="lgcy-card__meta">
      <h3 class="lgcy-card__title">{{ product_title }}</h3>
      {%- if color_option != '' -%}
        <span class="lgcy-card__color">
          <span>{{ color_option }}</span>
          {%- if color_count > 1 -%}
            <span class="lgcy-card__color-count">{{ color_count }} Colors</span>
          {%- endif -%}
        </span>
      {%- endif -%}
    </div>
    <div class="lgcy-card__price{% if on_sale %} lgcy-card__price--sale{% endif %}">
      {%- if on_sale -%}
        <span class="lgcy-card__price--compare">{{ compare_price | money }}</span>
      {%- endif -%}
      <span>{{ price | money }}</span>
    </div>
  </div>
</a>

<script>
(function() {
  if (window.__lgcyCardInit) return;
  window.__lgcyCardInit = true;

  /* ── Toast ── */
  var toast = document.createElement('div');
  toast.className = 'lgcy-cart-toast';
  toast.setAttribute('aria-live', 'polite');
  document.body.appendChild(toast);

  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('lgcy-toast--show');
    clearTimeout(toast._timer);
    toast._timer = setTimeout(function() {
      toast.classList.remove('lgcy-toast--show');
    }, 2200);
  }

  /* ── Helpers ── */
  function openPanel(wrap) {
    var panel = wrap.querySelector('[data-quick-add-panel]');
    if (panel) panel.style.transform = 'translateY(0)';
  }

  function closePanel(wrap) {
    var panel = wrap.querySelector('[data-quick-add-panel]');
    if (panel) panel.style.transform = 'translateY(100%)';
  }

  function hidePlus(wrap) {
    var btn = wrap.querySelector('[data-plus-btn]');
    if (btn) btn.classList.add('lgcy-plus--hidden');
  }

  function showPlus(wrap) {
    var btn = wrap.querySelector('[data-plus-btn]');
    if (btn) btn.classList.remove('lgcy-plus--hidden');
  }

  /* ── Full reset when mouse leaves the entire image wrap ── */
  function bindWrap(wrap) {
    wrap.addEventListener('mouseleave', function() {
      closePanel(wrap);
      showPlus(wrap);
    });
  }

  document.querySelectorAll('[data-quick-add-wrap]').forEach(bindWrap);

  /* ── mouseover: plus btn hover → hide plus + open panel (multi-variant only) ── */
  document.addEventListener('mouseover', function(e) {
    var plusBtn = e.target.closest('[data-plus-btn]');
    if (plusBtn) {
      /* Single-variant: keep the + visible, don't open any panel */
      if (plusBtn.getAttribute('data-single-variant')) return;
      var wrap = plusBtn.closest('[data-quick-add-wrap]');
      if (wrap) {
        hidePlus(wrap);
        openPanel(wrap);
      }
      return;
    }

    /* Hovering inside the panel itself → keep open */
    var panel = e.target.closest('[data-quick-add-panel]');
    if (panel) {
      panel.style.transform = 'translateY(0)';
    }
  });

  /* ── mouseout: leaving plus btn or panel ── */
  document.addEventListener('mouseout', function(e) {
    /* Leaving the plus button */
    var plusBtn = e.target.closest('[data-plus-btn]');
    if (plusBtn) {
      var wrap = plusBtn.closest('[data-quick-add-wrap]');
      if (!wrap) return;
      var related = e.relatedTarget;
      /* Mouse moving into the panel — keep state, don't reset */
      if (related && related.closest('[data-quick-add-panel]')) return;
      /* Mouse left to somewhere outside panel — close + restore plus */
      closePanel(wrap);
      showPlus(wrap);
      return;
    }

    /* Leaving the panel */
    var panel = e.target.closest('[data-quick-add-panel]');
    if (panel) {
      var related = e.relatedTarget;
      var wrap = panel.closest('[data-quick-add-wrap]');
      /* Moving back onto the plus button — keep state */
      if (related && related.closest('[data-plus-btn]')) return;
      /* Still inside the wrap (e.g. between size buttons) — do nothing */
      if (related && related.closest('[data-quick-add-wrap]') === wrap) return;
      /* Left the panel entirely — close + restore plus */
      if (wrap) {
        closePanel(wrap);
        showPlus(wrap);
      }
    }
  });

  /* ── Add to cart — uses Dawn's renderContents so the drawer opens exactly
     like the native add-to-cart button does ── */
  function addToCart(variantId, btn) {
    btn.classList.add('lgcy-adding');
    btn.disabled = true;

    var cartDrawer = document.querySelector('cart-drawer');
    var sections = cartDrawer && typeof cartDrawer.getSectionsToRender === 'function'
      ? cartDrawer.getSectionsToRender().map(function(s) { return s.id; })
      : ['cart-drawer', 'cart-icon-bubble'];

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        id: variantId,
        quantity: 1,
        sections: sections,
        sections_url: window.location.pathname
      })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.status && data.status !== 200) {
        showToast(data.description || 'Could not add to cart');
        return;
      }
      /* Hand off to Dawn's CartDrawer.renderContents() — this updates the
         drawer HTML with fresh cart data AND opens the drawer */
      if (cartDrawer && typeof cartDrawer.renderContents === 'function') {
        cartDrawer.renderContents(data);
      } else {
        showToast('Added to cart');
      }
    })
    .catch(function() {
      showToast('Something went wrong');
    })
    .finally(function() {
      btn.classList.remove('lgcy-adding');
      btn.disabled = false;
    });
  }

  /* ── Mobile helper ── */
  function isTouchDevice() {
    return window.matchMedia('(hover: none) and (pointer: coarse)').matches;
  }

  function closeMobilePanel(wrap) {
    closePanel(wrap);
    var btn = wrap.querySelector('[data-plus-btn]');
    if (btn) btn.classList.remove('lgcy-panel-open');
  }

  function closeAllMobilePanels() {
    document.querySelectorAll('.lgcy-card__plus-btn.lgcy-panel-open').forEach(function(b) {
      var w = b.closest('[data-quick-add-wrap]');
      if (w) closeMobilePanel(w);
    });
  }

  /* ── Click handlers ── */
  document.addEventListener('click', function(e) {
    /* Tapping outside any card on mobile → close open panels */
    if (isTouchDevice() && !e.target.closest('[data-quick-add-wrap]')) {
      closeAllMobilePanels();
      return;
    }

    /* Plus button clicked */
    var plusBtn = e.target.closest('[data-plus-btn]');
    if (plusBtn) {
      var singleId = plusBtn.getAttribute('data-single-variant');

      /* Single-variant: add directly to cart on all devices */
      if (singleId) {
        e.preventDefault();
        e.stopPropagation();
        addToCart(parseInt(singleId, 10), plusBtn);
        return;
      }

      /* Multi-variant on mobile: toggle size panel open/closed */
      if (isTouchDevice()) {
        e.preventDefault();
        e.stopPropagation();
        var wrap = plusBtn.closest('[data-quick-add-wrap]');
        if (!wrap) return;
        var isOpen = plusBtn.classList.contains('lgcy-panel-open');
        /* Close any other open panels first */
        closeAllMobilePanels();
        if (!isOpen) {
          openPanel(wrap);
          plusBtn.classList.add('lgcy-panel-open');
        }
        return;
      }

      /* Desktop: do nothing on click (hover handles it) */
      return;
    }

    /* Size button → add selected variant to cart */
    var sizeBtn = e.target.closest('.lgcy-card__size-btn');
    if (sizeBtn && !sizeBtn.disabled) {
      e.preventDefault();
      e.stopPropagation();
      var variantId = sizeBtn.getAttribute('data-variant-id');
      if (variantId) {
        addToCart(parseInt(variantId, 10), sizeBtn);
        /* Close panel on mobile after size selection */
        if (isTouchDevice()) {
          var wrap = sizeBtn.closest('[data-quick-add-wrap]');
          if (wrap) closeMobilePanel(wrap);
        }
      }
    }
  });

  /* ── Re-bind wraps added dynamically (infinite scroll etc.) ── */
  var observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(m) {
      m.addedNodes.forEach(function(node) {
        if (node.nodeType !== 1) return;
        var wraps = node.querySelectorAll ? node.querySelectorAll('[data-quick-add-wrap]') : [];
        wraps.forEach(bindWrap);
      });
    });
  });
  observer.observe(document.body, { childList: true, subtree: true });

})();
</script>

{%- if section.blocks.size > 0 -%}
 
{%- for block in section.blocks -%}
 
{%- assign img_url = block.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
 
{% if template == 'password' %}
  <style>
    /* Page background: force black so the video can fill the viewport
       without the body's scheme-1 white showing through any gap. */
    html,
    body.password,
    body.password.gradient {
      background: #000 !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    /* Kill the <hr> separators added by main-password-header/footer sections —
       they render as white horizontal lines top and bottom of the video. */
    body.password hr {
      display: none !important;
    }

    /* Make sure the (visually-hidden) password header/footer section wrappers
       don't reserve any height that exposes the body bg as a white border. */
    body.password .shopify-section-main-password-header,
    body.password .shopify-section-main-password-footer,
    body.password #shopify-section-main-password-header,
    body.password #shopify-section-main-password-footer {
      display: none !important;
    }

    /* Stretch the video container edge-to-edge */
    body.password .videoBackground,
    body.password .videoBox,
    body.password .fullscreen-video-wrap {
      margin: 0 !important;
    }

    /* Mobile: lock the password page to exactly the visible viewport so the
       video fills the screen without leaving body-bg (black) below it.
       100vh on mobile counts the area behind the browser chrome (address bar),
       so we use 100dvh — the *dynamic* viewport height — which always matches
       what the user actually sees. overflow:hidden also kills scroll. */
    @media (max-width: 749px) {
      html.full-height,
      body.password {
        height: 100vh; /* fallback */
        height: 100dvh;
        min-height: 100dvh;
        overflow: hidden !important;
      }

      body.password .password-main,
      body.password .videoBackground,
      body.password .videoBox,
      body.password .fullscreen-video-wrap {
        height: 100vh !important; /* fallback */
        height: 100dvh !important;
        min-height: 100dvh !important;
        max-height: 100dvh !important;
      }

      body.password .videoBackground .video-js,
      body.password .videoBackground video {
        height: 100% !important;
        min-height: 100% !important;
      }

      /* Force the video element + its wrap to a fixed full-viewport box.
         Bypasses any flex/section container heights that might be shorter
         than the visible area on mobile and lets the video sit edge-to-edge. */
      body.password .videoBackground .fullscreen-video-wrap {
        position: fixed !important;
        inset: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        height: 100dvh !important;
        z-index: 0 !important;
      }
      body.password .videoBackground .video-js,
      body.password .videoBackground video {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        height: 100dvh !important;
        object-fit: cover !important;
        z-index: 0 !important;
      }
    }

    #password-header-form {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 9999;
    }
  </style>

  <style>
/* Desktop */
#password-header-form {
  position: absolute;
  top: 55%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 9999;
  width: calc(100vw - 48px);
  margin: 0 auto;
}

@media (min-width: 750px) {
  #password-header-form {
    width: 820px;
  }
}

/* LGCYCLOTHING brand heading inside the omnisend embed — tighten the letter
   spacing and force max font weight on every heading level / common omnisend
   title class so the brand mark reads cleanly regardless of which tag the
   embed uses. */
#password-header-form [id^="omnisend-embedded-v2"] h1,
#password-header-form [id^="omnisend-embedded-v2"] h2,
#password-header-form [id^="omnisend-embedded-v2"] h3,
#password-header-form [id^="omnisend-embedded-v2"] h4,
#password-header-form [id^="omnisend-embedded-v2"] h5,
#password-header-form [id^="omnisend-embedded-v2"] h6,
#password-header-form [id^="omnisend-embedded-v2"] [class*="title" i],
#password-header-form [id^="omnisend-embedded-v2"] [class*="heading" i],
#password-header-form [id^="omnisend-embedded-v2"] [class*="brand" i] {
  letter-spacing: -0.05em !important;
  font-weight: 900 !important;
}

/* Mobile: keep the form centered, slightly wider, and shrink the omnisend
   heading directly so it doesn't wrap to one-word-per-line and dominate the
   form. Targeting all heading levels + the embed's body text catches whichever
   tag Omnisend ends up rendering. */
@media (max-width: 749px) {
  #password-header-form {
    /* Pin to the viewport directly (not the section ancestor) so 50% is the
       actual middle of what the user sees, not 50% of a possibly taller box. */
    position: fixed !important;
    top: 55% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) scale(0.86);
    transform-origin: center center;
    width: calc(100vw - 12px);
    padding: 12px 16px 12px;
  }

  #password-header-form [id^="omnisend-embedded-v2"] h1,
  #password-header-form [id^="omnisend-embedded-v2"] h2,
  #password-header-form [id^="omnisend-embedded-v2"] h3,
  #password-header-form [id^="omnisend-embedded-v2"] [class*="title"],
  #password-header-form [id^="omnisend-embedded-v2"] [class*="Title"] {
    font-size: 22px !important;
    line-height: 1.15 !important;
    letter-spacing: -0.01em !important;
    margin: 0 0 10px !important;
    max-width: 100% !important;
    word-break: normal !important;
    overflow-wrap: normal !important;
  }
}

</style>

<div id="password-header-form">
  <div id="omnisend-embedded-v2-69b47c72e1b57dccf6b8730a"></div>
  <div class="password-form-stack">
    <button type="button" class="password-enter-btn" onclick="var d=document.querySelector('details.password-modal');if(d){d.open=true;}">Enter using password</button>
    <p class="password-form-copyright">&copy; 2026 LGCYCLOTHING</p>
  </div>
</div>



{% endif %}

 
{% if block.type == 'video' %}
 
<div class="videoBox" style="background-color: #000;{%- if block.settings.video_link == blank and block.settings.video_image != blank -%}background-image: url('{{ block.settings.video_image  | img_url: 'master' }}');{%- endif -%}">



{%- if block.settings.video_link != blank -%}

<div class="fullscreen-video-wrap">

<video class="video-js" loop autoplay preload="auto" muted playsinline
 {%- if block.settings.video_image != blank %} poster="https:{{ block.settings.video_image | img_url: 'master' }}"{%- endif %}>

<source src="{{ block.settings.video_link }}" type="video/mp4">

</video>
 
</div>
 


{% endif %}
 
 
 
 
<div class="videoBoxInfo">
 
{% if block.settings.title != blank %}
 
<h1 class="videoBoxInfoTitle">
  {{ block.settings.title | escape }}
</h1>
 
{% endif %}
 
 
 
{%- style -%}
 
.videoBackground .imageBoxInfoDescription p {
 
color: {{ block.settings.color_text }}!important;
 
}
 
{%- endstyle -%}
 
 
 
{% if block.settings.text != blank %}
 
<div class="imageBoxInfoDescription" id="{{ block.id }}" style="color: {{ block.settings.color_text }}">
 
{{ block.settings.text }}
 
</div>
 
{% endif %}
 
 
 
{% if block.settings.button_link != blank and block.settings.button_label != blank %}
 
<a href="{{ block.settings.button_link }}" class="videoBoxInfoBtn" style="color: {{ block.settings.color_btn_text }}; background: {{ block.settings.color_btn_bg }}">
 
{{ block.settings.button_label | escape }}
 
</a>
 
{% endif %}
 
</div>
 
</div>
 
{% else %}
 
<div class="imageBox" style="background-color: {{ block.settings.color_bg }}; {%- if block.settings.image_bg != blank -%}background-image: url('{{ block.settings.image_bg | img_url: 'master' }}');{%- endif -%}">
 
 
 
 
 
 
<div class="imageBoxInfo">
 
{% if block.settings.title != blank %}
 
<h1 class="imageBoxInfoTitle" style="color: {{ block.settings.color_text }}">
 
{{ block.settings.title | escape }}
 
</h1>
 
{% endif %}
 
 
 
{%- style -%}
 
.videoBackground .imageBoxInfoDescription p {
 
color: {{ block.settings.color_text }}!important;
 
}
 
{%- endstyle -%}
 
 
 
{% if block.settings.text != blank %}
 
<div class="imageBoxInfoDescription" id="{{ block.id }}" style="color: {{ block.settings.color_text }}">
 
{{ block.settings.text }}
 
</div>
 
{% endif %}
 
 
 
{% if block.settings.button_link != blank and block.settings.button_label != blank %}
 
<a href="{{ block.settings.button_link }}" class="imageBoxInfoBtn" style="color: {{ block.settings.color_btn_text }}; background: {{ block.settings.color_btn_bg }}">
 
{{ block.settings.button_label | escape }}
 
</a>
 
{% endif %}
 
</div>
 
</div>
 
{% endif %}
 
{%- endfor -%}
 
 
 
{% else %}
 
<div class="placeholderNoblocks">
 
This section doesn’t currently include any content. Add content to this section using the sidebar.
 
    </div>
 
{%- endif -%}
 
 
 

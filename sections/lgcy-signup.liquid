<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">

<style>
  .lgcy-signup {
    height: 100vh;
    min-height: 600px;
    background: #0a0a0a;
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 48px;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .lgcy-signup__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.18;
    pointer-events: none;
  }

  .lgcy-signup__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(12px) brightness(0.6);
  }

  /* ── Animated blurred orb background (Represent-style) ────────────────── */
  .lgcy-signup__orbs {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  /* Blur is on each orb individually (not the container) — keeps motion
     visible and avoids browsers compositing the whole layer as static. */
  .lgcy-signup__orbs::before,
  .lgcy-signup__orbs::after,
  .lgcy-signup__orb {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(55px);
    -webkit-filter: blur(55px);
    will-change: transform;
    opacity: 1;
  }
  .lgcy-signup__orbs::before {
    width: 55vw;
    height: 55vw;
    top: -15%;
    left: -15%;
    background: radial-gradient(circle, #7a7a7a 0%, #2a2a2a 50%, rgba(10,10,10,0) 80%);
    animation: lgcyOrbA 12s linear infinite;
  }
  .lgcy-signup__orbs::after {
    width: 50vw;
    height: 50vw;
    bottom: -20%;
    right: -10%;
    background: radial-gradient(circle, #5e5e5e 0%, #232323 50%, rgba(10,10,10,0) 80%);
    animation: lgcyOrbB 14s linear infinite;
  }
  .lgcy-signup__orb--3 {
    width: 46vw;
    height: 46vw;
    top: 20%;
    left: 35%;
    background: radial-gradient(circle, #8a8a8a 0%, #2c2c2c 45%, rgba(10,10,10,0) 75%);
    animation: lgcyOrbC 16s linear infinite;
  }
  .lgcy-signup__orb--4 {
    width: 42vw;
    height: 42vw;
    top: 50%;
    left: -10%;
    background: radial-gradient(circle, #6b6b6b 0%, #1f1f1f 50%, rgba(10,10,10,0) 80%);
    animation: lgcyOrbD 10s linear infinite;
  }

  /* Multi-waypoint loops that return to start position without "alternate" —
     means the motion never pauses or reverses, it keeps drifting in a
     continuous closed loop. */
  @keyframes lgcyOrbA {
    0%   { transform: translate3d(0, 0, 0)         scale(1); }
    25%  { transform: translate3d(18vw, 10vw, 0)   scale(1.12); }
    50%  { transform: translate3d(22vw, 24vw, 0)   scale(1.18); }
    75%  { transform: translate3d(6vw, 18vw, 0)    scale(1.08); }
    100% { transform: translate3d(0, 0, 0)         scale(1); }
  }
  @keyframes lgcyOrbB {
    0%   { transform: translate3d(0, 0, 0)          scale(1); }
    25%  { transform: translate3d(-14vw, -8vw, 0)   scale(1.1); }
    50%  { transform: translate3d(-22vw, -18vw, 0)  scale(1.2); }
    75%  { transform: translate3d(-8vw, -22vw, 0)   scale(1.05); }
    100% { transform: translate3d(0, 0, 0)          scale(1); }
  }
  @keyframes lgcyOrbC {
    0%   { transform: translate3d(0, 0, 0)         scale(1); }
    25%  { transform: translate3d(-12vw, 12vw, 0)  scale(0.9); }
    50%  { transform: translate3d(-22vw, 20vw, 0)  scale(0.85); }
    75%  { transform: translate3d(-10vw, 6vw, 0)   scale(0.95); }
    100% { transform: translate3d(0, 0, 0)         scale(1); }
  }
  @keyframes lgcyOrbD {
    0%   { transform: translate3d(0, 0, 0)         scale(1); }
    25%  { transform: translate3d(14vw, -10vw, 0)  scale(1.1); }
    50%  { transform: translate3d(24vw, -18vw, 0)  scale(1.15); }
    75%  { transform: translate3d(12vw, -6vw, 0)   scale(1.05); }
    100% { transform: translate3d(0, 0, 0)         scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lgcy-signup__orbs::before,
    .lgcy-signup__orbs::after,
    .lgcy-signup__orb {
      animation: none !important;
    }
  }

  /* ── Two-column layout — text left, form right ────────────────────────── */
  .lgcy-signup__wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1480px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .lgcy-signup__col-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .lgcy-signup__col-form {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
  }

  .lgcy-signup__eyebrow {
    font-weight: 900;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin: 0 0 14px;
  }

  .lgcy-signup__heading {
    font-weight: 900;
    font-size: clamp(36px, 5.4vw, 68px);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 0.95;
    margin: 0 0 18px;
  }

  .lgcy-signup__sub {
    font-weight: 400;
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255,255,255,0.6);
    margin: 0 0 26px;
    max-width: 520px;
  }

  .lgcy-signup__perks {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .lgcy-signup__perks li {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    padding-left: 18px;
    position: relative;
  }

  .lgcy-signup__perks li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: rgba(255,255,255,0.4);
  }

  /* ── Form slot — frosted glass card (same recipe as password page) ── */
  .lgcy-signup__form-slot {
    width: 100%;
    max-width: 880px;
    margin-bottom: 8px;
    background: rgba(0, 0, 0, 0.48);
    -webkit-backdrop-filter: blur(18px);
            backdrop-filter: blur(18px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    padding: 40px 48px 32px;
    box-sizing: border-box;
  }

  .lgcy-signup__app-block + .lgcy-signup__app-block {
    margin-top: 12px;
  }

  /* ── Inputs / select inside the form — translucent, white text, Inter ── */
  .lgcy-signup__form-slot input[type="email"],
  .lgcy-signup__form-slot input[type="text"],
  .lgcy-signup__form-slot input[type="tel"],
  .lgcy-signup__form-slot input[type="number"],
  .lgcy-signup__form-slot input[type="search"],
  .lgcy-signup__form-slot select {
    background: rgba(255, 255, 255, 0.07) !important;
    border: 1px solid rgba(255, 255, 255, 0.18) !important;
    color: #fff !important;
    font-family: 'Inter', sans-serif !important;
    font-weight: 500 !important;
    border-radius: 8px !important;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .lgcy-signup__form-slot input::placeholder {
    color: rgba(255, 255, 255, 0.45) !important;
    font-weight: 400 !important;
  }
  .lgcy-signup__form-slot input:focus,
  .lgcy-signup__form-slot select:focus {
    background: rgba(255, 255, 255, 0.12) !important;
    border-color: rgba(255, 255, 255, 0.35) !important;
    outline: none !important;
  }

  /* ── Submit button — white pill, Inter 900 ── */
  .lgcy-signup__form-slot button[type="submit"],
  .lgcy-signup__form-slot [type="submit"] {
    background: #fff !important;
    color: #000 !important;
    border: none !important;
    border-radius: 999vw !important;
    padding: 14px 32px !important;
    font-family: 'Inter', sans-serif !important;
    font-weight: 900 !important;
    font-size: 13px !important;
    letter-spacing: 0.04em !important;
    text-transform: uppercase !important;
    cursor: pointer !important;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .lgcy-signup__form-slot button[type="submit"]:hover,
  .lgcy-signup__form-slot [type="submit"]:hover {
    background: rgba(255, 255, 255, 0.88) !important;
    transform: scale(0.99);
  }

  /* ── Checkbox + small disclaimer text ── */
  .lgcy-signup__form-slot label,
  .lgcy-signup__form-slot small,
  .lgcy-signup__form-slot p,
  .lgcy-signup__form-slot a {
    color: rgba(255, 255, 255, 0.75) !important;
    font-family: 'Inter', sans-serif !important;
    font-weight: 400 !important;
  }
  .lgcy-signup__form-slot label {
    font-weight: 500 !important;
  }
  .lgcy-signup__form-slot a {
    text-decoration: underline;
    color: rgba(255, 255, 255, 0.9) !important;
  }

  @media (max-width: 749px) {
    .lgcy-signup__form-slot {
      padding: 28px 20px 24px;
      border-radius: 12px;
    }
  }

  .lgcy-signup__empty-slot {
    border: 1px dashed rgba(255,255,255,0.25);
    padding: 18px 20px;
    color: rgba(255,255,255,0.55);
    font-size: 12px;
    line-height: 1.6;
  }

  .lgcy-signup__empty-slot p {
    margin: 0 0 6px;
  }

  .lgcy-signup__empty-slot p:last-child {
    margin: 0;
  }

  .lgcy-signup__disclaimer {
    font-size: 11px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255,255,255,0.3);
    margin: 20px 0 0;
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .lgcy-signup {
      padding: 60px 20px;
      align-items: flex-start;
    }
  }
</style>

<div class="lgcy-signup">
  {%- if section.settings.background_image != blank -%}
    <div class="lgcy-signup__bg">
      <img
        src="{{ section.settings.background_image | image_url: width: 1600 }}"
        alt=""
        loading="lazy"
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
      >
    </div>
  {%- endif -%}

  <div class="lgcy-signup__orbs" aria-hidden="true">
    <div class="lgcy-signup__orb lgcy-signup__orb--3"></div>
    <div class="lgcy-signup__orb lgcy-signup__orb--4"></div>
  </div>

  <div class="lgcy-signup__wrap">
    <p class="lgcy-signup__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="lgcy-signup__heading">{{ section.settings.heading }}</h1>
    <p class="lgcy-signup__sub">{{ section.settings.subtext }}</p>

    {%- if section.blocks.size > 0 -%}
      <ul class="lgcy-signup__perks">
        {%- for block in section.blocks -%}
          {%- if block.type == 'perk' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- comment %} ── Omnisend form slot — add the "Omnisend Embedded Form" app block here ── {% endcomment %}
    <div class="lgcy-signup__form-slot">
      {%- assign app_block_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          {%- assign app_block_count = app_block_count | plus: 1 -%}
          <div class="lgcy-signup__app-block" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment %} Empty slot waits for the Omnisend Embedded Form app block,
         added inside this section via the theme editor. {% endcomment -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "LGCY Signup",
  "tag": "section",
  "class": "section-lgcy-signup",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Inner Circle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join The Legacy."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be first. Get exclusive drops, early access to new collections, and member-only discounts — straight to your inbox or phone."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "No spam. Unsubscribe anytime. By entering your phone number you agree to receive SMS marketing."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Perk text",
          "default": "Early access to every drop"
        }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "LGCY Signup",
      "blocks": [
        { "type": "perk", "settings": { "text": "Early access to every drop" } },
        { "type": "perk", "settings": { "text": "Member-only discounts" } },
        { "type": "perk", "settings": { "text": "Behind the scenes content" } },
        { "type": "perk", "settings": { "text": "Free shipping on first order" } }
      ]
    }
  ]
}
{% endschema %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">

<style>
  .lgcy-signup {
    min-height: 100vh;
    background: #0a0a0a;
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    position: relative;
    overflow: hidden;
  }

  .lgcy-signup__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.18;
    pointer-events: none;
  }

  .lgcy-signup__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(12px) brightness(0.6);
  }

  .lgcy-signup__wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .lgcy-signup__eyebrow {
    font-weight: 900;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin: 0 0 16px;
  }

  .lgcy-signup__heading {
    font-weight: 900;
    font-size: clamp(44px, 8vw, 80px);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 0.95;
    margin: 0 0 20px;
  }

  .lgcy-signup__sub {
    font-weight: 400;
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin: 0 0 32px;
    max-width: 440px;
  }

  .lgcy-signup__perks {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .lgcy-signup__perks li {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    padding-left: 18px;
    position: relative;
  }

  .lgcy-signup__perks li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: rgba(255,255,255,0.4);
  }

  /* ── Form slot (holds Omnisend embedded form app block) ── */
  .lgcy-signup__form-slot {
    width: 100%;
    margin-bottom: 8px;
  }

  .lgcy-signup__app-block + .lgcy-signup__app-block {
    margin-top: 12px;
  }

  .lgcy-signup__empty-slot {
    border: 1px dashed rgba(255,255,255,0.25);
    padding: 18px 20px;
    color: rgba(255,255,255,0.55);
    font-size: 12px;
    line-height: 1.6;
  }

  .lgcy-signup__empty-slot p {
    margin: 0 0 6px;
  }

  .lgcy-signup__empty-slot p:last-child {
    margin: 0;
  }

  .lgcy-signup__disclaimer {
    font-size: 11px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255,255,255,0.3);
    margin: 20px 0 0;
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .lgcy-signup {
      padding: 60px 20px;
      align-items: flex-start;
    }
  }
</style>

<div class="lgcy-signup">
  {%- if section.settings.background_image != blank -%}
    <div class="lgcy-signup__bg">
      <img
        src="{{ section.settings.background_image | image_url: width: 1600 }}"
        alt=""
        loading="lazy"
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
      >
    </div>
  {%- endif -%}

  <div class="lgcy-signup__wrap">
    <p class="lgcy-signup__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="lgcy-signup__heading">{{ section.settings.heading }}</h1>
    <p class="lgcy-signup__sub">{{ section.settings.subtext }}</p>

    {%- if section.blocks.size > 0 -%}
      <ul class="lgcy-signup__perks">
        {%- for block in section.blocks -%}
          {%- if block.type == 'perk' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- comment %} ── Omnisend form slot — add the "Omnisend Embedded Form" app block here ── {% endcomment %}
    <div class="lgcy-signup__form-slot">
      {%- assign app_block_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          {%- assign app_block_count = app_block_count | plus: 1 -%}
          <div class="lgcy-signup__app-block" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment %} Empty slot waits for the Omnisend Embedded Form app block,
         added inside this section via the theme editor. {% endcomment -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "LGCY Signup",
  "tag": "section",
  "class": "section-lgcy-signup",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Inner Circle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join The Legacy."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be first. Get exclusive drops, early access to new collections, and member-only discounts — straight to your inbox or phone."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "No spam. Unsubscribe anytime. By entering your phone number you agree to receive SMS marketing."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Perk text",
          "default": "Early access to every drop"
        }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "LGCY Signup",
      "blocks": [
        { "type": "perk", "settings": { "text": "Early access to every drop" } },
        { "type": "perk", "settings": { "text": "Member-only discounts" } },
        { "type": "perk", "settings": { "text": "Behind the scenes content" } },
        { "type": "perk", "settings": { "text": "Free shipping on first order" } }
      ]
    }
  ]
}
{% endschema %}

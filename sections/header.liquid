<style>
  /* Pin the entire header section to the very top of the viewport */
  .section-header {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    width: 100% !important;
    z-index: 10010 !important;
    margin: 0 !important;
  }

  sticky-header {
    display: block;
    position: static !important;
  }

  .shopify-section-header-sticky {
    display: block;
  }

  /* Full-width header — items hug the screen edges */
  .header.page-width {
    max-width: 100% !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
  }

  .header-wrapper {
    position: relative !important;
    top: auto !important;
    width: 100%;
    background: transparent !important;
  }

  .header-wrapper .list-menu span,
  .lgcy-shop-btn,
  details[open]>.header__menu-item,
  .header-wrapper summary svg,
  .header-wrapper a svg,
  .header-wrapper h1.header__heading span.h2,
  .header-wrapper details>span,
  .header-wrapper .disclosure__button>span,
  .header-wrapper .disclosure__button svg {
    color: {% if request.page_type == 'index' or request.page_type == 'collection' or request.page_type == 'cart' %}#ffffff{% else %}#000000{% endif %} !important;
  }

  {% if request.page_type == 'product' %}
  .header__heading-logo {
    filter: invert(1);
    mix-blend-mode: normal;
  }

  @media screen and (max-width: 989px) {
    .header-wrapper {
      position: relative !important;
    }
  }
  {% endif %}

  .header-wrapper--border-bottom {
    border-bottom: .1rem solid rgba(255, 255, 255, .08);
  }

  .overflow-hidden-desktop .header-wrapper,
  .overflow-hidden-tablet .header-wrapper {
    position: initial;
    width: initial;
    background: var(--gradient-background) !important;
    mix-blend-mode: normal;
  }

  /* ── Clean search modal ── */
  details[open] > .search-modal {
    background: #0a0a0a;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .search-modal {
    background: #0a0a0a;
  }

  /* Replace muddy semi-transparent overlay with clean solid */
  details[open] .modal-overlay::after {
    background-color: rgba(0, 0, 0, 0.75) !important;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  /* Search input clean styling */
  .search-modal .field__input,
  .search-modal .search__input {
    background: rgba(255,255,255,0.06) !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    border-radius: 2px !important;
    color: #ffffff !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 14px !important;
    font-weight: 300 !important;
    letter-spacing: 0.05em !important;
    caret-color: #fff;
  }

  .search-modal .field__input::placeholder,
  .search-modal .search__input::placeholder {
    color: rgba(255,255,255,0.35) !important;
    font-family: 'Inter', sans-serif !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    font-size: 12px !important;
  }

  .search-modal .field__input:focus,
  .search-modal .search__input:focus {
    border-color: rgba(255,255,255,0.3) !important;
    outline: none !important;
    box-shadow: none !important;
  }

  /* Icons white */
  .search-modal svg,
  .search-modal .icon {
    color: rgba(255,255,255,0.6) !important;
    stroke: rgba(255,255,255,0.6) !important;
  }

  .search-modal .search-modal__close-button svg,
  .search-modal .search-modal__close-button .icon {
    color: rgba(255,255,255,0.5) !important;
    stroke: rgba(255,255,255,0.5) !important;
  }
</style>

{%- unless request.page_type == 'index' or request.page_type == 'collection' -%}
<style>
  .section-header {
    position: fixed !important;
    top: 0 !important;
    z-index: 10010 !important;
  }
  {%- unless request.page_type == 'cart' -%}
  .header__inline-menu .list-menu__item--link,
.lgcy-shop-btn,
.header__heading-link,
.header__icon {
  mix-blend-mode: difference;
}
  {%- endunless -%}

  .section-header.overflow-hidden-desktop,
  .section-header.overflow-hidden-tablet,
  .section-header.overflow-hidden-mobile {
    mix-blend-mode: normal !important;
  }

  /* Push page content below the fixed header so it doesn't overlap.
     Header is ≈ 72px tall; adding extra so the gap looks balanced with the bottom
     of the page rather than crammed right under the icons. */
  @media screen and (max-width: 989px) {
    #MainContent {
      padding-top: 96px;
    }
  }

  /* Desktop: the header is also fixed here, so offset the page content by the
     measured header height (set by the sticky-header JS) plus a little breathing
     room, otherwise the page title sits behind the logo/icons. */
  @media screen and (min-width: 990px) {
    #MainContent {
      padding-top: calc(var(--header-height, 90px) + 24px);
    }
  }

  /* These pages have a light/white background, so the default white logo is
     nearly invisible — invert it to dark (same treatment as product pages).
     Excluded on cart, which uses a dark glass background (logo stays white). */
  {%- unless request.page_type == 'cart' -%}
  .header__heading-logo {
    filter: invert(1);
    mix-blend-mode: normal;
  }
  {%- endunless -%}
</style>
{%- endunless -%}


{{ 'lgcy-collection.css' | asset_url | stylesheet_tag }}

<div class="lgcy-faq-clean">
  <div class="lgcy-faq-clean__inner">
    <p class="lgcy-faq-clean__eyebrow">{{ section.settings.faq_title }}</p>
    <p class="lgcy-faq-clean__subtitle">{{ section.settings.faq_subtitle }}</p>

    <div class="lgcy-faq-clean__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          <div class="lgcy-faq-clean__item" {{ block.shopify_attributes }}>
            <button class="lgcy-faq-clean__question" aria-expanded="false">
              <span>{{ block.settings.question }}</span>
              <svg class="lgcy-faq-clean__chevron" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lgcy-faq-clean__answer">
              <div class="lgcy-faq-clean__answer-inner">{{ block.settings.answer }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.lgcy-faq-clean__question').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.lgcy-faq-clean__item');
      var isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.lgcy-faq-clean__item.is-open').forEach(function (el) {
        el.classList.remove('is-open');
        el.querySelector('.lgcy-faq-clean__question').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

{% schema %}
{
  "name": "LGCY FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "faq_title",
      "label": "Section Title",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "faq_subtitle",
      "label": "Section Subtitle",
      "default": "Your questions, answered."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LGCY FAQ Section"
    }
  ]
}
{% endschema %}

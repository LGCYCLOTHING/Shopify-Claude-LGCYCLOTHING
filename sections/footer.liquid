{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,300&family=Playfair+Display:ital,wght@1,500;1,700&family=Inter:wght@300;400;500;900&display=swap" rel="stylesheet">

<footer class="lgcy-footer">
  <div class="lgcy-footer__main">
    <div class="lgcy-footer__grid page-width">

      <div class="lgcy-footer__col lgcy-footer__col--brand">
        <a href="{{ routes.root_url }}" class="lgcy-footer__brand-name">LGCYCLOTHING</a>
        <span class="lgcy-footer__tagline">&#8216;Iconic Visionary.&#8217;</span>
        <hr class="lgcy-footer__brand-divider">
        <span class="lgcy-footer__est">Est. 2026</span>

        <a href="https://www.instagram.com/_lgcyclothing_/" target="_blank" rel="noopener" class="lgcy-footer__ugc">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
            <circle cx="12" cy="13" r="3.5"/>
          </svg>
          <span>Wear it — tag <strong>@_lgcyclothing_</strong></span>
        </a>
      </div>

      <div class="lgcy-footer__col lgcy-footer__col--nav">
        <nav class="lgcy-footer__nav">
          <a href="{{ routes.all_products_collection_url }}" class="lgcy-footer__nav-link">Shop</a>
          <a href="/pages/about" class="lgcy-footer__nav-link">About</a>
          <a href="{{ routes.account_url }}/orders" class="lgcy-footer__nav-link">Orders</a>
          <a href="/policies/refund-policy" class="lgcy-footer__nav-link">Returns</a>
          <a href="/pages/contact" class="lgcy-footer__nav-link">Contact</a>
        </nav>

        <div class="lgcy-footer__support">
          <a href="mailto:support@lgcyclothing.com" class="lgcy-footer__support-email">support@lgcyclothing.com</a>
          <span class="lgcy-footer__support-meta">Replies within 24h</span>
        </div>
      </div>

      <div class="lgcy-footer__col lgcy-footer__col--newsletter">
        {%- form 'customer', id: 'ContactFooter', class: 'lgcy-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <p class="lgcy-footer__newsletter-label">Join the Vision.</p>
          <p class="lgcy-footer__newsletter-incentive">10% off your first drop &middot; early access</p>
          <div class="lgcy-footer__newsletter-field">
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="lgcy-footer__newsletter-input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
              {% endif %}
              placeholder="Email"
              required
            >
            <button
              type="submit"
              class="lgcy-footer__newsletter-btn"
              name="commit"
              aria-label="{{ 'newsletter.button_label' | t }}"
            >→</button>
          </div>
          {%- if form.errors -%}
            <small class="lgcy-footer__newsletter-msg lgcy-footer__newsletter-msg--error">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </small>
          {%- endif -%}
          {%- if form.posted_successfully? -%}
            <p class="lgcy-footer__newsletter-msg lgcy-footer__newsletter-msg--success" tabindex="-1" autofocus>
              Thank you for subscribing.
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>

    </div>
  </div>

  <div class="lgcy-footer__bottom">
    <div class="lgcy-footer__bottom-wrapper page-width">
      <div class="lgcy-footer__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}</small>
        {%- if section.settings.show_policy -%}
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <small>· <a href="{{ policy.url }}">{{ policy.title | escape }}</a></small>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if shop.enabled_payment_types.size > 0 -%}
        <ul class="lgcy-footer__payment" role="list" aria-label="Payment methods">
          {%- for type in shop.enabled_payment_types -%}
            <li class="lgcy-footer__payment-item">{{ type | payment_type_svg_tag: class: 'lgcy-footer__payment-icon' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if shop.enabled_currencies.size > 1 -%}
        {%- form 'localization', class: 'lgcy-footer__locale-form' -%}
          <select name="currency_code" class="lgcy-footer__locale-select" onchange="this.form.submit()" aria-label="Currency">
            {%- for currency in shop.enabled_currencies -%}
              <option value="{{ currency.iso_code }}"{% if currency.iso_code == cart.currency.iso_code %} selected{% endif %}>
                {{ currency.iso_code }} {{ currency.symbol }}
              </option>
            {%- endfor -%}
          </select>
        {%- endform -%}
      {%- endif -%}

      <div class="lgcy-footer__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="lgcy-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="lgcy-footer__social-link" target="_blank" rel="noopener" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="lgcy-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__8.content",
      "info": "t:sections.footer.settings.header__8.info"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "t:sections.footer.settings.show_policy.label"
    }
  ]
}
{% endschema %}

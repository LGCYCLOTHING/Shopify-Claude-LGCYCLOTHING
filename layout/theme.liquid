<script>
  /* PDP breadcrumbs + gallery dot pagination. Both inject into the existing
     custom-liquid product layout without touching the template file. */
  (function () {
    function init() {
      var info = document.querySelector('.rp-info');
      var inner = document.querySelector('.rp-inner');
      var gallery = document.querySelector('.rp-gallery');
      if (!inner || !gallery) return;

      // ── Breadcrumbs ─────────────────────────────────────────────────
      if (!inner.querySelector('.lgcy-breadcrumbs')) {
        var titleEl = inner.querySelector('.rp-title, h1') ||
                      document.querySelector('.rp-title, h1');
        var titleText = (titleEl && titleEl.textContent.trim()) ||
                        document.title.split('|')[0].trim();

        // Try to derive the collection from the current URL.
        // /collections/[handle]/products/[handle] → use the collection in the path.
        // Otherwise fall back to the document.referrer if it's a collection page.
        var collectionHandle = null;
        var pathMatch = window.location.pathname.match(/\/collections\/([^/]+)\/products\//);
        if (pathMatch) {
          collectionHandle = pathMatch[1];
        } else if (document.referrer) {
          try {
            var refUrl = new URL(document.referrer);
            if (refUrl.host === window.location.host) {
              var refMatch = refUrl.pathname.match(/^\/collections\/([^/]+)\/?$/);
              if (refMatch) collectionHandle = refMatch[1];
            }
          } catch (e) {}
        }

        var collectionLabel = 'All';
        var collectionHref = '/collections/all';
        if (collectionHandle) {
          collectionHref = '/collections/' + collectionHandle;
          collectionLabel = collectionHandle
            .split('-')
            .map(function (w) { return w.charAt(0).toUpperCase() + w.slice(1); })
            .join(' ');
        }

        var crumbs = document.createElement('nav');
        crumbs.className = 'lgcy-breadcrumbs';
        crumbs.setAttribute('aria-label', 'Breadcrumb');
        crumbs.innerHTML =
          '<a href="/">Home</a>' +
          '<span class="lgcy-breadcrumbs__sep" aria-hidden="true">&rsaquo;</span>' +
          '<a class="lgcy-breadcrumbs__collection" href=""></a>' +
          '<span class="lgcy-breadcrumbs__sep" aria-hidden="true">&rsaquo;</span>' +
          '<span class="lgcy-breadcrumbs__current"></span>';
        var collectionLink = crumbs.querySelector('.lgcy-breadcrumbs__collection');
        collectionLink.href = collectionHref;
        collectionLink.textContent = collectionLabel;
        crumbs.querySelector('.lgcy-breadcrumbs__current').textContent = titleText;

        // Place breadcrumbs DIRECTLY AFTER the entire title row (.rp-header
        // wraps the title + price), so they sit on their own line below.
        var titleHost = inner.querySelector('.rp-header') ||
                        inner.querySelector('.rp-title');
        // If only the title was found, walk up to its parent row
        if (titleHost && titleHost.classList.contains('rp-title')) {
          titleHost = titleHost.parentElement || titleHost;
        }
        if (titleHost && titleHost.parentNode) {
          var nextSibling = titleHost.nextSibling;
          if (nextSibling) {
            titleHost.parentNode.insertBefore(crumbs, nextSibling);
          } else {
            titleHost.parentNode.appendChild(crumbs);
          }
        } else {
          inner.insertBefore(crumbs, inner.firstChild);
        }
      }

      // ── Gallery dot pagination ──────────────────────────────────────
      var counter = document.getElementById('rp-counter');
      if (counter && !gallery.querySelector('.lgcy-gallery-dots')) {
        var match = (counter.textContent || '').match(/(\d+)\s*\/\s*(\d+)/);
        if (match) {
          var total = parseInt(match[2], 10);
          if (total > 1) {
            var dots = document.createElement('div');
            dots.className = 'lgcy-gallery-dots';
            dots.setAttribute('role', 'tablist');
            for (var i = 0; i < total; i++) {
              var dot = document.createElement('button');
              dot.type = 'button';
              dot.className = 'lgcy-gallery-dot';
              dot.setAttribute('aria-label', 'Image ' + (i + 1));
              dot.setAttribute('data-idx', i);
              if (i === 0) dot.classList.add('is-active');
              dot.addEventListener('click', (function (idx) {
                return function () {
                  if (typeof window.rpSetImg === 'function') window.rpSetImg(idx);
                };
              })(i));
              dots.appendChild(dot);
            }
            gallery.appendChild(dots);

            // Sync active dot with the existing rp-counter
            new MutationObserver(function () {
              var m = (counter.textContent || '').match(/(\d+)\s*\/\s*(\d+)/);
              if (!m) return;
              var current = parseInt(m[1], 10) - 1;
              dots.querySelectorAll('.lgcy-gallery-dot').forEach(function (d, i) {
                d.classList.toggle('is-active', i === current);
              });
            }).observe(counter, { childList: true, characterData: true, subtree: true });
          }
        }
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<script>
  /* Sticky mobile Add-to-Cart bar — when the real ATC scrolls out of view on
     small screens, slide a glass pill in from the bottom of the viewport. */
  (function () {
    function init() {
      var atc = document.querySelector('.rp-btn-cart');
      if (!atc) return;

      // Mobile only; bail on desktop
      if (!window.matchMedia('(max-width: 860px)').matches) return;

      // Already injected?
      if (document.querySelector('.lgcy-sticky-atc')) return;

      // Build the sticky bar
      var bar = document.createElement('div');
      bar.className = 'lgcy-sticky-atc';
      bar.innerHTML =
        '<div class="lgcy-sticky-atc__sizes" role="group"></div>' +
        '<button type="button" class="lgcy-sticky-atc__btn">' +
        '<span class="lgcy-sticky-atc__price"></span>' +
        '<span class="lgcy-sticky-atc__label">ADD TO CART</span>' +
        '<span class="lgcy-sticky-atc__arrow" aria-hidden="true">&rarr;</span>' +
        '</button>';
      document.body.appendChild(bar);

      var stickyBtn = bar.querySelector('.lgcy-sticky-atc__btn');
      var priceEl = bar.querySelector('.lgcy-sticky-atc__price');
      var sizesEl = bar.querySelector('.lgcy-sticky-atc__sizes');

      // Mirror the page's size buttons into the sticky bar
      var origSizes = document.querySelectorAll('.rp-size');
      if (origSizes.length === 0) {
        sizesEl.style.display = 'none';
      } else {
        origSizes.forEach(function (orig) {
          var pill = document.createElement('button');
          pill.type = 'button';
          pill.className = 'lgcy-sticky-atc__size';
          pill.textContent = orig.textContent.trim();
          if (orig.classList.contains('soldout') || orig.disabled) {
            pill.classList.add('is-soldout');
          }
          if (orig.classList.contains('active')) {
            pill.classList.add('is-active');
          }
          pill.addEventListener('click', function () {
            try { orig.click(); } catch (e) {}
          });
          sizesEl.appendChild(pill);
        });

        // Keep sticky pills in sync when the user picks a size up on the page
        new MutationObserver(function () {
          var pills = sizesEl.querySelectorAll('.lgcy-sticky-atc__size');
          origSizes.forEach(function (orig, i) {
            var p = pills[i];
            if (!p) return;
            p.classList.toggle('is-active', orig.classList.contains('active'));
            p.classList.toggle(
              'is-soldout',
              orig.classList.contains('soldout') || orig.disabled
            );
          });
        }).observe(document.querySelector('.rp-sizes') || document.body, {
          subtree: true,
          attributes: true,
          attributeFilter: ['class', 'disabled']
        });
      }

      // Try to mirror the visible price on the page
      var srcPrice = document.querySelector('.rp-price, [data-rp-price]');
      if (srcPrice && srcPrice.textContent.trim()) {
        priceEl.textContent = srcPrice.textContent.trim();
      }

      // AJAX add to cart and open the cart drawer instead of redirecting
      function ajaxAdd() {
        var variantInput = document.querySelector('#rp-vid, input[name="id"]');
        var variantId = variantInput && variantInput.value;
        if (!variantId || stickyBtn.disabled) return;

        stickyBtn.disabled = true;
        stickyBtn.classList.add('is-loading');

        var cartDrawer = document.querySelector('cart-drawer');
        var sections =
          cartDrawer && typeof cartDrawer.getSectionsToRender === 'function'
            ? cartDrawer.getSectionsToRender().map(function (s) { return s.id; })
            : ['cart-drawer', 'cart-icon-bubble'];

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({
            id: parseInt(variantId, 10),
            quantity: 1,
            sections: sections,
            sections_url: window.location.pathname
          })
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data && data.status && data.status !== 200) return;
            if (cartDrawer && typeof cartDrawer.renderContents === 'function') {
              cartDrawer.renderContents(data);
            }
          })
          .finally(function () {
            stickyBtn.disabled = false;
            stickyBtn.classList.remove('is-loading');
          });
      }

      stickyBtn.addEventListener('click', function (e) {
        e.preventDefault();
        ajaxAdd();
      });

      // Also hijack the original ATC form submit so the inline button (and any
      // future click on the real ATC) doesn't redirect to /cart either.
      var atcForm = atc.closest('form');
      if (atcForm && !atcForm.dataset.lgcyAjax) {
        atcForm.dataset.lgcyAjax = '1';
        atcForm.addEventListener('submit', function (e) {
          e.preventDefault();
          ajaxAdd();
        });
      }

      // Sync disabled / sold-out state from the real ATC
      function syncState() {
        if (atc.disabled || atc.classList.contains('disabled')) {
          stickyBtn.disabled = true;
          bar.classList.add('is-disabled');
        } else {
          stickyBtn.disabled = false;
          bar.classList.remove('is-disabled');
        }
      }
      syncState();
      new MutationObserver(syncState).observe(atc, { attributes: true });

      // Always visible on mobile (no scroll-trigger)
      bar.classList.add('is-visible');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<script>
  /* Notify-me on PDP: products without sizes (sunglasses, etc.) don't render
     the existing .rp-size-nis button. Inject one and adapt the modal so the
     size dropdown is hidden when the product has no real sizes. */
  (function () {
    function init() {
      var atc = document.querySelector('.rp-btn-cart');
      if (!atc) return;

      var info = atc.closest('.rp-info') || atc.parentElement;
      if (!info || info.dataset.lgcyNotify === '1') return;

      // If the size-NIS button already exists on this product, we're done
      if (info.querySelector('.rp-size-nis')) return;

      var sizeSelect = document.getElementById('rp-nis-size');
      // Real size options (skip the disabled placeholder)
      var realOptions = sizeSelect
        ? sizeSelect.querySelectorAll('option:not([disabled])')
        : [];
      var hasSizes = realOptions.length > 0;

      // If somehow sizes exist but the button isn't shown, don't double up
      if (hasSizes) return;

      info.dataset.lgcyNotify = '1';

      // Hide the size dropdown in the modal
      if (sizeSelect) sizeSelect.style.display = 'none';

      // Update the modal copy to drop the "size" reference
      var sub = document.querySelector('.rp-nis-sub');
      if (sub) {
        sub.textContent =
          "Enter your email and we'll let you know when this is back in stock.";
      }
      var title = document.querySelector('.rp-nis-title');
      if (title) title.textContent = 'Notify Me When Available';

      // Build the notify button (uses the same class as the multi-size version
      // so it inherits the existing styling)
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'rp-size-nis lgcy-nis-injected';
      btn.textContent = 'Notify When Available';
      btn.addEventListener('click', function () {
        if (typeof window.rpNisOpen === 'function') {
          window.rpNisOpen();
        } else {
          var modal = document.getElementById('rp-nis-modal');
          if (modal) modal.classList.add('open');
        }
      });

      // Place the button just AFTER the ATC form, left-aligned with minimal
      // padding so it sits as a small underlined link below the cart button.
      var atcForm = atc.closest('form') || atc;
      if (atcForm.nextSibling) {
        atcForm.parentNode.insertBefore(btn, atcForm.nextSibling);
      } else {
        atcForm.parentNode.appendChild(btn);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<script>
  (function () {
    var btn = document.getElementById('lgcy-back-to-top');
    if (!btn) return;
    var threshold = 600;
    var bottomGap = 120;
    var ticking = false;
    function update() {
      ticking = false;
      var y = window.scrollY;
      var distFromBottom = document.documentElement.scrollHeight - (y + window.innerHeight);
      var pastTop = y > threshold;
      var nearBottom = distFromBottom < bottomGap;
      if (pastTop && !nearBottom) btn.classList.add('is-visible');
      else btn.classList.remove('is-visible');
    }
    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
    btn.addEventListener('click', function () {
      var startY = window.scrollY;
      if (startY <= 0) return;
      var duration = Math.min(1200, Math.max(500, startY * 0.6));
      var startTime = null;
      function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
      function step(ts) {
        if (startTime === null) startTime = ts;
        var elapsed = ts - startTime;
        var t = Math.min(1, elapsed / duration);
        window.scrollTo(0, startY * (1 - easeOutCubic(t)));
        if (t < 1) window.requestAnimationFrame(step);
      }
      window.requestAnimationFrame(step);
    });
    update();
  })();
</script>


<script>
  /* PDP — open all accordion sections by default so all content is visible
     without clicks. */
  (function () {
    function init() {
      var triggers = document.querySelectorAll('.rp-acc-trigger');
      if (!triggers.length) return;
      triggers.forEach(function (t) {
        if (!t.classList.contains('open')) {

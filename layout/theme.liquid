/* Default state for navbar links (no underline) */
.header__inline-menu a {
    color: black !important; /* Text color */
    text-decoration: none; /* Remove default underline */
    position: relative; /* Set position for the pseudo-element */
    display: inline-block; /* Ensures the width is based on the text */
    line-height: 1; /* Ensures the pseudo-element aligns closely with the text */
    transition: color 0.3s ease; /* Smooth color transition */
}

/* When hovering over a navbar link, remove the default underline and add the custom one */
.header__inline-menu a:hover {
    color: black !important; /* Keep the text color black on hover */
    text-decoration: none !important; /* Remove the default browser underline on hover */
}

/* =========================================
   NAV LINK BASE STYLE

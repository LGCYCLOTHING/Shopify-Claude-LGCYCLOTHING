<!doctype html>
<html class="js" lang="{{ request.locale.iso_code }}">
  <head>
 <script>
   /* LGCY Grid Wipe boot — set the incoming flag before paint so the
      overlay can render covered the instant the new page loads.
      Skip on mobile (≤749px) — the wipe doesn't run there. */
   try {
     if (window.matchMedia('(max-width: 749px)').matches) {
       sessionStorage.removeItem('lgcy-wipe-incoming');
     } else if (sessionStorage.getItem('lgcy-wipe-incoming') === '1') {
       document.documentElement.classList.add('lgcy-wipe-incoming');
     }
   } catch (e) {}
 </script>
 <style>
   /* Inline so the cover state is in effect before any external CSS loads.
      Kills the brief flash of new-page-content before the overlay is set. */
   #lgcy-wipe {
     position: fixed !important;
     top: 0 !important; right: 0 !important;
     bottom: 0 !important; left: 0 !important;
     z-index: 2147483646 !important;
     pointer-events: none;
     opacity: 0;
     margin: 0; padding: 0;
   }
   html.lgcy-wipe-incoming #lgcy-wipe {
     opacity: 1 !important;
     background: #ffffff !important;
     background-color: #ffffff !important;
     pointer-events: auto !important;
   }
 </style>
 <link rel="stylesheet" href="{{ 'lgcy-grid-wipe.css' | asset_url }}">
 <link rel="stylesheet" href="{{ 'lgcy-instafeed.css' | asset_url }}">
 <script src="{{ 'lgcy-instafeed.js' | asset_url }}" defer></script>
 <script src="{{ 'lgcy-collection-title.js' | asset_url }}"></script>

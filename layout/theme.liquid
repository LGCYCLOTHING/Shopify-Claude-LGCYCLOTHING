<script>
(function() {
  function initHeroExit() {
    var label = document.getElementById('explore-label');
    var indicator = document.getElementById('scroll-indicator');
    var glasses = document.getElementById('glassesReveal');

    if (!label || !indicator || !glasses) return;

    var glassesSection = glasses.closest('.shopify-section') || glasses;
    var ticking = false;

    function update() {
      var rect = glassesSection.getBoundingClientRect();
      var winH = window.innerHeight;
      var isMobile = window.innerWidth <= 768;
      var baseY = isMobile ? 48 : 100;
      var yShift = 0;

      if (rect.bottom <= 0) {
        yShift = winH;
      } else if (rect.bottom < winH) {
        yShift = winH - rect.bottom;
      }

      var newY = baseY - yShift;
      var t = 'translate(-50%, ' + newY + 'px)';
      indicator.style.setProperty('transform', t, 'important');
      label.style.setProperty('transform', t, 'important');

      ticking = false;
    }

    window.addEventListener('scroll', function() {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });

    window.addEventListener('resize', update, { passive: true });
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroExit);
  } else {
    initHeroExit();
  }
})();
</script>

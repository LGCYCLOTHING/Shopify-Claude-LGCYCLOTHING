{"sections":{"custom_liquid_rMJ6mW":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<p id=\"explore-label\" style=\"\n  position: fixed;\n  top: 48%;\n  left: 50%;\n  transform: translate(-50%, 100px);\n  z-index: 10000;\n  font-family: 'Inter', Helvetica, Arial, sans-serif;\n  font-size: 10px;\n  font-weight: 600;\n  letter-spacing: 0.05em;\n  color: #ffffff;\n  text-transform: uppercase;\n  margin: 0 0 6px 0;\n  padding: 0;\n  pointer-events: none;\n  line-height: 1;\n  text-align: center;\n  width: 90vw;\n  max-width: 600px;\n\">EXPLORE COLLECTIONS<\/p>\n\n<div id=\"scroll-indicator\" style=\"\n  position: fixed;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, 100px);\n  z-index: 9999;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0;\n  pointer-events: all;\n  text-align: center;\n  width: 90vw;\n  max-width: 600px;\n  mix-blend-mode: difference;\n\">\n  <div style=\"height: 15px;\"><\/div>\n\n  <span class=\"scroll-label\" data-index=\"0\"\n    data-url=\"https:\/\/0dc7p1-tw.myshopify.com\/collections\/the-legacy-collection\"\n    style=\"\n    font-family: 'Inter', Helvetica, Arial, sans-serif;\n    font-size: clamp(18px, 3vw, 28px);\n    font-weight: 900;\n    letter-spacing: -0.03em;\n    color: rgba(255,255,255,1);\n    opacity: 1;\n    transition: color 0.4s ease, opacity 0.4s ease;\n    text-transform: uppercase;\n    cursor: pointer;\n    display: block;\n    line-height: 1.1;\n    margin: 0;\n    padding: 0;\n  \">'ICONIC VISIONARY'<\/span>\n\n  <span class=\"scroll-label\" data-index=\"1\"\n    data-url=\"https:\/\/0dc7p1-tw.myshopify.com\/collections\/lgcy-glasses\"\n    style=\"\n    font-family: 'Inter', Helvetica, Arial, sans-serif;\n    font-size: clamp(18px, 3vw, 28px);\n    font-weight: 900;\n    letter-spacing: -0.03em;\n    color: rgba(255,255,255,0.3);\n    opacity: 0.5;\n    transition: color 0.4s ease, opacity 0.4s ease;\n    text-transform: uppercase;\n    cursor: pointer;\n    display: block;\n    line-height: 1.1;\n    margin: 0;\n    padding: 0;\n  \">LGCY.<\/span>\n\n  <div style=\"height: 48px;\"><\/div>\n  <a id=\"scroll-discover\" href=\"#\" style=\"margin-top: 48px;\">→ DISCOVER<\/a>\n<\/div>\n\n<style>\n  \/* ─── MOBILE CONTROLS ─── *\/\n  @media (max-width: 768px) {\n\n    \/* Position of the whole indicator on mobile *\/\n    #scroll-indicator {\n      transform: translate(-50%, 48px) !important;\n      top: 50%; \/* change this to move the block up\/down *\/\n    }\n\n    #explore-label {\n      transform: translate(-50%, 48px) !important;\n      top: 48%; \/* should match or sit just above scroll-indicator top *\/\n      font-size: 9px; \/* \"EXPLORE COLLECTIONS\" font size on mobile *\/\n      letter-spacing: 0.12em;\n    }\n\n    \/* Collection label font sizes on mobile *\/\n    .scroll-label {\n      font-size: 28px !important; \/* overrides the clamp() *\/\n      letter-spacing: -0.02em !important;\n    }\n\n    \/* → DISCOVER link on mobile *\/\n    #scroll-discover {\n      font-size: 12px !important;\n      letter-spacing: 0.0em !important;\n    }\n\n    \/* Gap between collection labels and discover button *\/\n    #scroll-indicator > div:last-of-type {\n      height: 32px !important;\n    }\n  }\n\n  \/* ─── DESKTOP STYLES ─── *\/\n  #scroll-discover {\n    font-family: 'Inter', Helvetica, Arial, sans-serif;\n    font-size: 15px;\n    font-weight: 700;\n    letter-spacing: 0.0em;\n    color: rgba(255,255,255,1);\n    text-transform: uppercase;\n    text-decoration: none;\n    margin: 0;\n    padding: 0 0 3px 0;\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    line-height: 1;\n    position: relative;\n  }\n\n  #scroll-discover::after {\n    content: '';\n    position: absolute;\n    bottom: 0;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 0%;\n    height: 1px;\n    background: rgba(255,255,255,1);\n    opacity: 0;\n    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;\n  }\n\n  #scroll-discover:hover::after {\n    width: 100%;\n    opacity: 1;\n  }\n<\/style>\n\n<script>\n(function() {\n  function init() {\n    const labels = document.querySelectorAll('.scroll-label');\n    const discoverBtn = document.getElementById('scroll-discover');\n\n    let SWITCH_THRESHOLD = window.innerHeight * 0.3;\n\n    function setActive(index) {\n      labels.forEach((label, i) => {\n        if (i === index) {\n          label.style.color = 'rgba(255,255,255,1)';\n          label.style.opacity = '1';\n        } else {\n          label.style.color = 'rgba(255,255,255,0.3)';\n          label.style.opacity = '0.5';\n        }\n      });\n      const url = labels[index] ? labels[index].getAttribute('data-url') : '#';\n      discoverBtn.href = url;\n    }\n\n    function update() {\n      const scrollY = window.scrollY;\n      if (scrollY > SWITCH_THRESHOLD) {\n        setActive(1);\n      } else {\n        setActive(0);\n      }\n    }\n\n    const allSections = Array.from(document.querySelectorAll('.shopify-section'));\n    const sections = allSections.filter(s =>\n      !s.classList.contains('section-header') &&\n      !s.classList.contains('section-footer') &&\n      !s.querySelector('#scroll-indicator')\n    );\n\n    let clickTimer = null;\n    labels.forEach((label, i) => {\n      label.addEventListener('click', () => {\n        if (clickTimer) {\n          clearTimeout(clickTimer);\n          clickTimer = null;\n          window.location.href = label.getAttribute('data-url');\n          return;\n        }\n        clickTimer = setTimeout(() => {\n          clickTimer = null;\n          const target = sections[i];\n          if (target) {\n            target.scrollIntoView({ behavior: 'smooth' });\n          } else {\n            window.scrollTo({ top: i * window.innerHeight, behavior: 'smooth' });\n          }\n        }, 250);\n      });\n    });\n\n    window.addEventListener('scroll', update, { passive: true });\n    window.addEventListener('resize', function() {\n      SWITCH_THRESHOLD = window.innerHeight * 0.3;\n    }, { passive: true });\n\n    update();\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n<\/script>","color_scheme":"","padding_top":0,"padding_bottom":0}},"custom_liquid_VVJUFg":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<div id=\"hero-title\" style=\"\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  z-index: 999;\n  mix-blend-mode: exclusion;\n  pointer-events: none;\n  text-align: center;\n  width: 90vw;\n  max-width: 100%;\n\">\n  <h1 style=\"\n    font-family: 'Inter', Helvetica, Arial, sans-serif;\n    font-size: clamp(28px, 8vw, 77px);\n    font-weight: 900;\n    letter-spacing: -3px;\n    color: #ffffff;\n    margin: 0;\n    padding: 0;\n    line-height: 1.1;\n    text-transform: uppercase;\n    mix-blend-mode: exclusion;\n    -webkit-mix-blend-mode: exclusion;\n    white-space: nowrap;\n  \">LGCYCLOTHING<\/h1>\n<\/div>\n<style>\n  @media (max-width: 768px) {\n    #hero-title h1 {\n      font-size: clamp(24px, 9.5vw, 45px) !important;\n      letter-spacing: -1.5px !important;\n      white-space: nowrap;\n    }\n  }\n<\/style>","color_scheme":"","padding_top":0,"padding_bottom":0}},"background_video_WTHRPk":{"type":"background-video","blocks":{"video_gbTacA":{"type":"video","settings":{"video_link":"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/21d1b3e0c558412081d9ea6dc0701fb6.mp4","video_image":"shopify:\/\/shop_images\/white-image.png","title":"","text":"","color_text":"#ffffff","button_label":"","button_link":"shopify:\/\/collections\/the-legacy-collection","color_btn_bg":"rgba(0,0,0,0)","color_btn_text":"#ffffff"}}},"block_order":["video_gbTacA"],"custom_css":[],"settings":{}},"custom_liquid_iEwLeL":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<div id=\"glassesReveal\" style=\"position:relative; width:100%; cursor:none; overflow:hidden;\">\n  <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/4537\/1578\/files\/ChatGPT_Image_Mar_16_2026_06_36_27_PM.png?v=1773700624\" style=\"display:block; width:100%; height:auto;\">\n  <div id=\"glassesTop\" style=\"position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none;\">\n    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/4537\/1578\/files\/ChatGPT_Image_Mar_16_2026_06_36_24_PM.png?v=1773700625\" style=\"width:100%; height:100%; object-fit:cover; display:block;\">\n  <\/div>\n<\/div>\n\n<style>\n#glassesTop {\n  -webkit-mask-size: 100% 100%;\n  mask-size: 100% 100%;\n  -webkit-mask-repeat: no-repeat;\n  mask-repeat: no-repeat;\n}\n<\/style>\n\n<script>\n(function() {\n  function init() {\n    const reveal = document.getElementById('glassesReveal');\n    const topLayer = document.getElementById('glassesTop');\n\n    \/\/ Small offscreen canvas — 25% resolution, much faster\n    const SCALE = 0.25;\n    const offscreen = document.createElement('canvas');\n    const ctx = offscreen.getContext('2d');\n\n    let mouseX = 0, mouseY = 0;\n    let hovering = false;\n    let blob = { x: 0, y: 0, size: 0 };\n    let sweep = { x: 0, y: 0, size: 0, direction: 1, row: 0, active: false };\n    let prevBlobX = 0, velX = 0;\n    let prevSweepX = 0, sweepVelX = 0;\n    let sweepTween = null;\n\n    function resize() {\n      offscreen.width = Math.floor(reveal.offsetWidth * SCALE);\n      offscreen.height = Math.floor(reveal.offsetHeight * SCALE);\n    }\n    resize();\n    window.addEventListener('resize', resize);\n\n    function scheduleNext() {\n      setTimeout(startAutoSequence, 5000 + Math.random() * 5000);\n    }\n\n    function startAutoSequence() {\n      if (hovering) { scheduleNext(); return; }\n      const w = reveal.offsetWidth;\n      const h = reveal.offsetHeight;\n      sweep.direction = sweep.row % 2 === 0 ? 1 : -1;\n      sweep.x = sweep.direction === 1 ? -150 : w + 150;\n      sweep.y = h * (0.25 + sweep.row * 0.2);\n      sweep.size = 0;\n      sweep.active = true;\n      sweep.row = (sweep.row + 1) % 4;\n\n      if (sweepTween) sweepTween.kill();\n      const targetX = sweep.direction === 1 ? w + 150 : -150;\n\n      gsap.to(sweep, { size: 1, duration: 0.4, ease: 'power2.out' });\n      sweepTween = gsap.to(sweep, {\n        x: targetX,\n        duration: 2.5,\n        ease: 'power2.inOut',\n        onUpdate: () => {\n          sweepVelX = sweep.x - prevSweepX;\n          prevSweepX = sweep.x;\n        },\n        onComplete: () => {\n          gsap.to(sweep, {\n            size: 0, duration: 0.4, ease: 'power2.in',\n            onComplete: () => { sweep.active = false; scheduleNext(); }\n          });\n        }\n      });\n    }\n\n    scheduleNext();\n\n    reveal.addEventListener('mouseenter', (e) => {\n      const rect = reveal.getBoundingClientRect();\n      mouseX = e.clientX - rect.left;\n      mouseY = e.clientY - rect.top;\n      blob.x = mouseX;\n      blob.y = mouseY;\n      hovering = true;\n      gsap.to(blob, { size: 1, duration: 0.5, ease: 'elastic.out(1, 0.5)' });\n    });\n\n    reveal.addEventListener('mousemove', (e) => {\n      const rect = reveal.getBoundingClientRect();\n      mouseX = e.clientX - rect.left;\n      mouseY = e.clientY - rect.top;\n      gsap.to(blob, { x: mouseX, y: mouseY, duration: 0.6, ease: 'power3.out', overwrite: 'auto' });\n    });\n\n    reveal.addEventListener('mouseleave', () => {\n      hovering = false;\n      gsap.to(blob, { size: 0, duration: 0.5, ease: 'power2.in' });\n    });\n\n    function drawBlob(x, y, size, t, vx) {\n      if (size < 0.01) return;\n      const s = SCALE;\n      const baseR = 120 * size * s;\n      const speed = Math.abs(vx * s);\n      const stretchX = 1 + Math.min(speed * 0.04, 2.5);\n      const stretchY = 1 \/ (1 + Math.min(speed * 0.02, 0.5));\n      const numPoints = 10;\n      const angleStep = (Math.PI * 2) \/ numPoints;\n      const pts = [];\n\n      for (let i = 0; i < numPoints; i++) {\n        const angle = i * angleStep - Math.PI \/ 2;\n        const wobble = baseR\n          + Math.sin(t * 1.2 + i * 2.0) * baseR * 0.25\n          + Math.cos(t * 0.7 + i * 1.5) * baseR * 0.15;\n        pts.push({\n          x: x * s + Math.cos(angle) * wobble * stretchX,\n          y: y * s + Math.sin(angle) * wobble * stretchY\n        });\n      }\n\n      ctx.beginPath();\n      for (let i = 0; i < numPoints; i++) {\n        const p0 = pts[(i - 1 + numPoints) % numPoints];\n        const p1 = pts[i];\n        const p2 = pts[(i + 1) % numPoints];\n        const p3 = pts[(i + 2) % numPoints];\n        const cp1x = p1.x + (p2.x - p0.x) \/ 6;\n        const cp1y = p1.y + (p2.y - p0.y) \/ 6;\n        const cp2x = p2.x - (p3.x - p1.x) \/ 6;\n        const cp2y = p2.y - (p3.y - p1.y) \/ 6;\n        if (i === 0) ctx.moveTo(p1.x, p1.y);\n        ctx.bezierCurveTo(cp1x, cp1y, cp2x, cp2y, p2.x, p2.y);\n      }\n      ctx.closePath();\n      ctx.fill();\n    }\n\n    function loop() {\n      const t = Date.now() \/ 800;\n\n      velX = blob.x - prevBlobX;\n      prevBlobX = blob.x;\n\n      ctx.clearRect(0, 0, offscreen.width, offscreen.height);\n      ctx.fillStyle = 'black';\n      ctx.fillRect(0, 0, offscreen.width, offscreen.height);\n      ctx.globalCompositeOperation = 'destination-out';\n\n      if (blob.size > 0.01) drawBlob(blob.x, blob.y, blob.size, t, velX);\n      if (sweep.active && sweep.size > 0.01) drawBlob(sweep.x, sweep.y, sweep.size, t + 5, sweepVelX * 10);\n\n      ctx.globalCompositeOperation = 'source-over';\n\n      \/\/ Apply as mask — dataURL at low quality is fast\n      const dataURL = offscreen.toDataURL('image\/png');\n      topLayer.style.webkitMaskImage = `url(${dataURL})`;\n      topLayer.style.maskImage = `url(${dataURL})`;\n\n      requestAnimationFrame(loop);\n    }\n\n    loop();\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n<\/script>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}},"image_banner_eHm8Mp":{"type":"image-banner","blocks":{"buttons_ViX67z":{"type":"buttons","settings":{"button_label_1":"LGCY","button_link_1":"shopify:\/\/collections\/lgcy-glasses","button_style_secondary_1":true,"button_label_2":"","button_link_2":"","button_style_secondary_2":false}}},"block_order":["buttons_ViX67z"],"disabled":true,"settings":{"image":"shopify:\/\/shop_images\/Blurry_road.jpg","image_overlay_opacity":0,"image_height":"large","desktop_content_position":"middle-center","show_text_box":false,"desktop_content_alignment":"center","color_scheme":"scheme-5","image_behavior":"none","mobile_content_alignment":"center","stack_images_on_mobile":false,"show_text_below":false}}},"order":["custom_liquid_rMJ6mW","custom_liquid_VVJUFg","background_video_WTHRPk","custom_liquid_iEwLeL","image_banner_eHm8Mp"]}